#!/usr/bin/env bash

# https://elv.sh/get/

# https://github.com/elves/elvish/releases <-- just source

# https://repology.org/project/elvish/versions

function setup_util_elvish() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='elvish'
		AUR='elvish'
		# DEB='elvish' -- outdated
		BREW='elvish'
		PORT='elvish'
		SCOOP='elvish'
		PKG='elvish'
		PKGIN='elvish'
		PKGADD='elvish'
		# NIX='elvish' -- outdated
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local arch
	arch="$(__get_arch)"
	function __add_download_option {
		local release url platform="$1" suffix="$2"
		release="$(get-github-release --slug='elves/elvish' --tag)" || return $? # v0.19.2
		url="https://dl.elv.sh/$platform/elvish-$release.$suffix"
		util_options+=(
			DOWNLOAD="$url"
			DOWNLOAD_ARCHIVE_EXTRACT='yes'
		)
	}
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__add_download_option 'darwin-arm64' 'tar.gz' || :
		elif [[ $arch == 'x64' ]]; then
			__add_download_option 'darwin-amd64' 'tar.gz' || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__add_download_option 'linux-arm64' 'tar.gz' || :
		elif [[ $arch == 'x64' ]]; then
			__add_download_option 'linux-amd64' 'tar.gz' || :
		elif [[ $arch == 'x32' ]]; then
			__add_download_option 'linux-386' 'tar.gz' || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_elvish "$@"
fi
