#!/usr/bin/env bash

# https://github.com/imsnif/bandwhich
# bandwidth monitor

# https://github.com/imsnif/bandwhich/releases
# bandwhich-v0.23.1-aarch64-apple-darwin.tar.gz
# bandwhich-v0.23.1-aarch64-linux-android.tar.gz
# bandwhich-v0.23.1-aarch64-unknown-linux-gnu.tar.gz
# bandwhich-v0.23.1-aarch64-unknown-linux-musl.tar.gz
# bandwhich-v0.23.1-armv7-unknown-linux-gnueabihf.tar.gz
# bandwhich-v0.23.1-armv7-unknown-linux-musleabihf.tar.gz
# bandwhich-v0.23.1-x86_64-apple-darwin.tar.gz
# bandwhich-v0.23.1-x86_64-pc-windows-msvc.zip
# bandwhich-v0.23.1-x86_64-unknown-linux-gnu.tar.gz
# bandwhich-v0.23.1-x86_64-unknown-linux-musl.tar.gz

# https://repology.org/project/bandwhich/versions

function setup_util_bandwhich() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='bandwhich'
		AUR='bandwhich'
		BREW='bandwhich'
		BSD='bandwhich'
		CARGO='bandwhich'
		DNF_COPR='atim/bandwhich'
		NIX='nixpkgs.bandwhich'
		XBPS='bandwhich'
	)
	if ! is-system --almalinux; then
		# almalinux is not aware of the DNF package
		util_options+=(DNF='bandwhich')
	fi

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='imsnif/bandwhich' glob='**/bandwhich' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-apple-darwin.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_bandwhich "$@"
fi
