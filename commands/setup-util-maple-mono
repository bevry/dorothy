#!/usr/bin/env bash

# https://github.com/subframe7536/maple-font

function setup_util_maple_mono() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Maple Mono'
		--font='MapleMono*'
		CASK='font-maple-mono'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	__fetch_and_add_download_option_via_slug_regexp_glob 'subframe7536/maple-font'  '^MapleMono-Variable\.zip$' '*.ttf' || :

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_maple_mono "$@"
fi
