#!/usr/bin/env bash

# https://github.com/dbrgn/tealdeer
# tldr alternative

# https://dbrgn.github.io/tealdeer/installing.html

# https://github.com/dbrgn/tealdeer/releases
# completions_bash
# completions_fish
# completions_zsh
# tealdeer-linux-arm-musleabi
# tealdeer-linux-arm-musleabihf
# tealdeer-linux-armv7-musleabihf
# tealdeer-linux-i686-musl
# tealdeer-linux-x86_64-musl
# tealdeer-macos-x86_64
# tealdeer-windows-x86_64-msvc.exe

function setup_util_tealdeer() (
	source "$DOROTHY/sources/util.bash"
	source "$(type -P setup-util)" # enable *_EVAL
	util_options=(
		--name='tealdeer'
		--cli='tldr'
		# apt is marked for removal
		AUR='tealdeer-bin'
		BREW='tealdeer'
		BSD='sysutils/tealdeer'
		CARGO='tealdeer'
		MACPORTS='tealdeer'
		NIX='tealdeer'
		RPM='tealdeer' # repology is wrong, `rust-tealdeer` is 404, correct is `tealdeer.x86_64`
		SCOOP='tealdeer'
		EOPKG='tealdeer'
		XBPS='tealdeer'
		ZYPPER='tealdeer'
		RECONFIGURE_INSTALLED_EVAL='__reconfigure'
	)
	function __reconfigure {
		# @todo figure out why this hangs forever on wsl
		if ! __is_wsl; then
			eval-helper --quiet --wrap -- tldr --update || return $?
		fi
	}

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='dbrgn/tealdeer' arch
	arch="$(__get_arch)"
	if __is_macos; then
		__fetch_and_add_download_option_via_slug_suffix "$slug" '-macos-x86_64' || :
	elif __is_linux; then
		if [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '-linux-x86_64-musl' || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '-linux-i686-musl' || :
		elif [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '-linux-arm-musleabihf' || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '-linux-armv7-musleabihf' || :
		fi
	fi

	# setup
	setup_util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_tealdeer "$@"
fi
