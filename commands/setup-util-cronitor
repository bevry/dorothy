#!/usr/bin/env bash

# https://github.com/cronitorio/cronitor-cli

# https://github.com/cronitorio/cronitor-cli/releases
# darwin_amd64.tar.gz
# darwin_arm64.tar.gz
# freebsd_amd64.tar.gz
# freebsd_arm.tar.gz
# freebsd_arm64.tar.gz
# linux_amd64.tar.gz
# linux_arm.tar.gz
# linux_arm64.tar.gz
# windows_amd64.zip

function setup_util_cronitor() (
	source "$DOROTHY/sources/util.bash"
	source "$(type -P setup-util)" # enable *_EVAL
	util_options=(
		--cli='cronitor'
		RECONFIGURE_INSTALLED_EVAL='__reconfigure'
	)
	function __reconfigure {
		# if xdg present, move it to a place sudo can access
		# @todo add support for this directly to setup-util, so that uninstalls work properly
		if [[ -x "$XDG_BIN_HOME/cronitor" ]]; then
			if __is_macos; then
				fs-move --elevate -- "$XDG_BIN_HOME/cronitor" '/usr/local/bin/cronitor' || return $?
			else
				fs-move --elevate -- "$XDG_BIN_HOME/cronitor" '/usr/bin/cronitor' || return $?
			fi
		fi

		# authenticate if necessary
		if ! cronitor status &>/dev/null; then
			local token
			token="$(
				ask --required \
					--question=$'What is your Cronitor API Key?\nYou get this from: https://cronitor.io/app/settings/api' \
					--default="${CRONITOR_API_KEY-}"
			)" || return $?
			eval-helper --elevate -- cronitor configure --api-key "$token" >/dev/null || return $?
		fi

		# ensure sudo access
		config-edit --local || return $?
	}

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='cronitorio/cronitor-cli' glob='cronitor' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" 'darwin_arm64.tar.gz' "$glob" || :
		else
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" 'darwin_amd64.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" 'linux_arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" 'linux_arm.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" 'linux_amd64.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup_util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_cronitor "$@"
fi
