# ghostty_1.2.3-0.ppa1_amd64_25.04.deb
# ghostty_1.2.3-0.ppa1_amd64_25.10.deb
# ghostty_1.2.3-0.ppa1_amd64_trixie.deb
# ghostty_1.2.3-0.ppa1_arm64_24.04.deb
# ghostty_1.2.3-0.ppa1_arm64_25.04.deb
# ghostty_1.2.3-0.ppa1_arm64_25.10.deb
# ghostty_1.2.3-0.ppa1_arm64_trixie.deb

# https://github.com/pkgforge-dev/ghostty-appimage/releases
# Ghostty-1.2.3-aarch64.AppImage
# Ghostty-1.2.3-x86_64.AppImage

# https://repology.org/project/ghostty/versions

function setup_util_ghostty() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Ghostty'
		--app='Ghostty'
		--app='com.mitchellh.ghostty' # .desktop
	)
	if __is_windows; then
		util_options+=(
			SCOOP_BUCKET='extras'
			SCOOP='ghostty'
			WINGET='smartfrigde.ghostty'
		)
	else
		util_options+=(
			AUR='ghostty'
			CASK='ghostty'
			DNF_COPR='scottames/ghostty'
			DNF='ghostty'
			NIX='ghostty'
			MACPORTS='ghostty'
			# SOAR='ghostty'
			# PACSTALL='ghostty-deb'
		)

		# improve performance for detectable utilities when fetching asset configuration
		if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
			return 0
		fi

		# fetch and use configuration
		local arch
		arch="$(__get_arch)"
		if __is_macos; then
			__fetch_and_add_download_option_via_slug_suffix 'ghostty-org/ghostty' '-macos-universal.zip' || :
		elif __is_linux; then
			if [[ $arch == 'a64' ]]; then
				__fetch_and_add_appimage_option_via_slug_suffix 'pkgforge-dev/ghostty-appimage' '-aarch64.AppImage' || :
			elif [[ $arch == 'x64' ]]; then
				__fetch_and_add_appimage_option_via_slug_suffix 'pkgforge-dev/ghostty-appimage' '-x86_64.AppImage' || :
			fi
			if is-system --debian; then
				local codename
				codename="$(get-system --codename)" || :
				if [[ -n $codename && $arch == 'x64' ]]; then
					__fetch_and_add_deb_option_via_slug_suffix 'dariogriffo/ghostty-debian' "+${codename}_amd64.deb" || :
				fi
			elif is-system --ubuntu; then
				local version
				version="$(get-system --version)" || :
				if [[ -n $version ]]; then
					if [[ $arch == 'a64' ]]; then
						__fetch_and_add_deb_option_via_slug_suffix 'mkasberg/ghostty-ubuntu' "_arm64_${version}.deb" || :
					elif [[ $arch == 'x64' ]]; then
						__fetch_and_add_deb_option_via_slug_suffix 'mkasberg/ghostty-ubuntu' "_amd64_${version}.deb" || :
					fi
				fi
			fi
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_ghostty "$@"
fi
