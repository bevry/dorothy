#!/usr/bin/env bash

# @todo add SOAR support to `setup-util`
# https://github.com/pkgforge/soar/discussions/113

# https://github.com/pkgforge/soar

# https://soar.qaidvoid.dev/installation
# CARGO=soar-cli

# https://github.com/pkgforge/soar/releases
# soar-aarch64-linux
# soar-aarch64-linux.b3sum
# soar-aarch64-linux.tar.gz
# soar-aarch64-linux.tar.gz.b3sum
# soar-riscv64-linux
# soar-riscv64-linux.b3sum
# soar-riscv64-linux.tar.gz
# soar-riscv64-linux.tar.gz.b3sum
# soar-x86_64-linux
# soar-x86_64-linux.b3sum
# soar-x86_64-linux.tar.gz
# soar-x86_64-linux.tar.gz.b3sum

# https://repology.org/project/soar/versions
# https://aur.archlinux.org/packages/soar-bin

function setup_util_soar() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='soar'
		AUR='soar-bin'
		CARGO='soar-cli'
		EVAL_UNINSTALL='soar self uninstall'
	)

	# checks
	if ! __is_linux; then
		__print_style --stderr --notice="[$0] is only intended to be run on Linux systems, skipping." || return $?
		return 0
	fi

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='pkgforge/soar' arch
	arch="$(__get_arch)"
	if __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '-aarch64-linux' || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '-x86_64-linux' || :
		elif [[ $arch == 'r64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '-riscv64-linux' || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_soar "$@"
fi
