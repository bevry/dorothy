#!/usr/bin/env bash

# https://github.com/raspberrypi/rpi-update

function setup_util_rpi_update() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--no-xdg
		--elevate
		--cli='rpi-update'
		APT='rpi-update'
		DOWNLOAD='https://raw.githubusercontent.com/raspberrypi/rpi-update/HEAD/rpi-update'
	)
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_rpi_update "$@"
fi
