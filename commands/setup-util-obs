#!/usr/bin/env bash

# https://github.com/obsproject/obs-studio/releases
# OBS-Studio-30.0-Full-Installer-x64.exe
# OBS-Studio-30.0.0-macOS-Apple-dSYMs.tar.xz
# OBS-Studio-30.0.0-macOS-Apple.dmg
# OBS-Studio-30.0.0-macOS-Intel-dSYMs.tar.xz
# OBS-Studio-30.0.0-macOS-Intel.dmg
# OBS-Studio-30.0.0-Ubuntu-x86_64-dbsym.ddeb
# OBS-Studio-30.0.0-Ubuntu-x86_64.deb
# OBS-Studio-30.0.zip
# obs-studio_30.0.0-0obsproject1.jammy_amd64.deb
# obs-studio_30.0.0-0obsproject1.lunar_amd64.deb
# obs-studio_30.0.0-0obsproject1.mantic_amd64.deb

# https://obsproject.com/download#linux

function setup_util_obs() (
	source "$DOROTHY/sources/util.bash"
	source "$(type -P setup-util)" # enable *_EVAL
	util_options=(
		--name='Open Broadcaster Software'
		--app='OBS'        # macos
		--app='OBS Studio' # flatpak
		--configure-eval='__configure'
		# prefer flatpak as with modifications it actually works, the others work but are half baked - no youtube plugins, no proper codec access
		--source='flatpak ...'
		CASK='obs'
		FLATPAK='com.obsproject.Studio'
	)
	function __configure {
		if [[ $SETUP_UTIL__INSTALLED == 'yes' ]]; then
			# if installed via flatpak
			if is-system --flatpak && setup-util "${util_options[@]}" is-installed --source='flatpak'; then
				# then fix flatpak wayland not having access to youtube plugin and codecs
				bash -c "$(fetch https://raw.githubusercontent.com/vol1t/OBS-Studio-Flatpak-XWayland-Universal-Fix/refs/heads/Main/obs-xwayland-fix.sh)"
			fi
		fi
	}

	# fetch and use configuration
	if __is_windows; then
		util_options+=(
			WINGET='XPFFH613W8V6LV'
		)
	else
		# improve performance for detectable utilities when fetching asset configuration
		if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
			return 0
		fi

		# fetch and use configuration
		local slug='obsproject/obs-studio' arch
		arch="$(__get_arch)"
		if __is_macos; then
			if [[ $arch == 'a64' ]]; then
				__fetch_and_add_dmg_option_via_slug_suffix_glob_filename "$slug" '-macOS-Apple.dmg' '*/OBS.app' 'OBS.app' || :
			elif [[ $arch == 'x64' ]]; then
				__fetch_and_add_dmg_option_via_slug_suffix_glob_filename "$slug" '-macOS-Intel.dmg' '*/OBS.app' 'OBS.app' || :
			fi
		elif [[ $arch == 'x64' ]] && is-system --ubuntu; then
			local suffix
			suffix=".$(get-system --codename)_amd64.deb" || return $?
			__fetch_and_add_deb_option_via_slug_suffix "$slug" "$suffix" || :
		fi
	fi

	# setup
	setup_util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_obs "$@"
fi
