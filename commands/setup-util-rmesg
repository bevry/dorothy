#!/usr/bin/env bash

# https://github.com/polyverse/rmesg
# https://github.com/polyverse/rmesg/releases
# dmesg alternative

function setup_util_rmesg() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='rmesg'
		CARGO='rmesg'
	)
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_rmesg "$@"
fi
