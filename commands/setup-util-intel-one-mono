#!/usr/bin/env bash

# https://github.com/intel/intel-one-mono

function setup_util_intel_one() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Intel One Mono'
		--font='IntelOneMono*'
		CASK='font-intel-one-mono'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	__fetch_and_add_download_option_via_slug_regexp_glob 'intel/intel-one-mono' '^otf\.zip$' '*/*.otf' || :

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_intel_one "$@"
fi
