#!/usr/bin/env bash

# https://github.com/ajeetdsouza/zoxide
# z/cd alternative

# apt option is requires debian testing, instead of debian stable

# https://github.com/ajeetdsouza/zoxide/releases
# zoxide-0.9.1-aarch64-apple-darwin.tar.gz
# zoxide-0.9.1-aarch64-pc-windows-msvc.zip
# zoxide-0.9.1-aarch64-unknown-linux-musl.tar.gz
# zoxide-0.9.1-arm-unknown-linux-musleabihf.tar.gz
# zoxide-0.9.1-armv7-unknown-linux-musleabihf.tar.gz
# zoxide-0.9.1-x86_64-apple-darwin.tar.gz
# zoxide-0.9.1-x86_64-pc-windows-msvc.zip
# zoxide-0.9.1-x86_64-unknown-linux-musl.tar.gz
# zoxide_0.9.1_amd64.deb
# zoxide_0.9.1_arm64.deb

# https://packages.debian.org/sid/amd64/zoxide/filelist
# /usr/bin/zoxide

function setup_util_zoxide() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='zoxide'
		--cli='z'
		APK='zoxide'
		AUR='zoxide-bin'
		BREW='zoxide'
		CARGO='zoxide'
		CONDA_CHANNEL='conda-forge'
		CONDA='zoxide'
		DNF_COPR='atim/zoxide'
		EMERGE_REPO='dm9pZCAq'
		EMERGE='app-shells/zoxide'
		NIX='nixpkgs.zoxide'
		SCOOP='zoxide'
		XBPS='zoxide'
	)
	if ! is-system --almalinux; then
		# almalinux is not aware of the DNF package
		util_options+=(DNF='zoxide')
	fi

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='ajeetdsouza/zoxide' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-apple-darwin.tar.gz' 'zoxide' || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' 'zoxide' || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_arm64.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-unknown-linux-musl.tar.gz' 'zoxide' || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-armv7-unknown-linux-musl.tar.gz' 'zoxide' || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_amd64.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-musl.tar.gz' 'zoxide' || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_zoxide "$@"
fi
