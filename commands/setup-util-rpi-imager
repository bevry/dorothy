#!/usr/bin/env bash

# https://www.raspberrypi.com/software/
# https://downloads.raspberrypi.com/imager/imager_latest_amd64.AppImage
# https://downloads.raspberrypi.com/imager/imager_latest.exe
# https://downloads.raspberrypi.com/imager/imager_latest.dmg

# https://github.com/raspberrypi/rpi-imager/releases
# imager-v2.0.0.exe
# Raspberry_Pi_Imager-v2.0.0-cli-aarch64.AppImage
# Raspberry_Pi_Imager-v2.0.0-cli-x86_64.AppImage
# Raspberry_Pi_Imager-v2.0.0-desktop-aarch64.AppImage
# Raspberry_Pi_Imager-v2.0.0-desktop-x86_64.AppImage
# Raspberry_Pi_Imager-v2.0.0-embedded-aarch64.AppImage
# rpi-imager-cli_2.0.0_arm64.deb
# rpi-imager-embedded_2.0.0_arm64.deb
# rpi-imager-v2.0.0.dmg
# rpi-imager_2.0.0.tar.xz
# rpi-imager_2.0.0_arm64.deb

# https://repology.org/project/rpi-imager/versions

function setup_util_rpi_imager() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--app='Raspberry Pi Imager'
	)

	# setup
	if __is_windows; then
		util_options+=(
			SCOOP_BUCKET='extras'
			SCOOP='raspberry-pi-imager'
			WINGET='RaspberryPiFoundation.RaspberryPiImager'
		)
	else
		# out of date: apt, aur, nix, rpm, flatpak, pacstall, void
		util_options+=(
			CASK='raspberry-pi-imager'
		)

		# improve performance for detectable utilities when fetching asset configuration
		if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
			return 0
		fi

		# fetch and use configuration
		local arch
		arch="$(__get_arch)"
		# have to use regexp due to inconsistent asset names: https://github.com/raspberrypi/rpi-imager/issues/1360
		if __is_macos; then
			__fetch_and_add_download_option_via_slug_suffix 'raspberrypi/rpi-imager' '^rpi-imager-v[.0-9]+[.]dmg$' || :
		elif __is_linux; then
			if [[ $arch == 'a64' ]]; then
				__fetch_and_add_deb_option_via_slug_regexp 'raspberrypi/rpi-imager' '^rpi-imager_[.0-9]+_arm64[.]deb$' || :
				__fetch_and_add_appimage_option_via_slug_regexp 'raspberrypi/rpi-imager' '-desktop-aarch64[.][Aa]pp[Ii]mage$' || :
			elif [[ $arch == 'x64' ]]; then
				__fetch_and_add_appimage_option_via_slug_regexp 'raspberrypi/rpi-imager' '-desktop-x86_64[.][Aa]pp[Ii]mage$' || :
			fi
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_rpi_imager "$@"
fi
