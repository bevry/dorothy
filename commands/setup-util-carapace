# carapace-bin_1.5.1_windows_arm64.zip

# https://repology.org/project/carapace/versions

function setup_util_carapace() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='carapace'
		--configure-eval='__configure'
		# couldn't get APT to work, APT_REPO was malformed
		AUR='carapace-bin'
		BREW_TAP='rsteube/homebrew-tap'
		BREW='rsteube/tap/carapace'
		NIX='carapace'
		SCOOP='carapace-bin'
		VOID='carapace'
		WINGET='rsteube.Carapace'
		YUM_REPO="$(
			cat <<-EOF
				[fury]
				name=Gemfury Private Repo
				baseurl=https://yum.fury.io/rsteube/
				enabled=1
				gpgcheck=0
			EOF
		)"
		YUM='carapace-bin'
	)
	function __configure {
		# reconfigure nushell if it exists, regardless of carapace existence
		if setup-util-nu is-installed; then
			setup-util-nu configure "${setup_options[@]}" || return $?
		fi
	}

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='carapace-sh/carapace-bin' glob='carapace' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_darwin_arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_darwin_amd64.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_apk_option_via_slug_suffix "$slug" '_linux_arm64.apk' || :
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_arm64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_arm64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_apk_option_via_slug_suffix "$slug" '_linux_amd64.apk' || :
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_amd64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_amd64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_amd64.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_apk_option_via_slug_suffix "$slug" '_linux_386.apk' || :
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_386.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_386.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_386.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup_util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_carapace "$@"
fi
