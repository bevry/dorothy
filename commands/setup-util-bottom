function setup_util_bottom() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='bottom'
		--cli='btm'
		AUR='bottom-bin'
		BREW='bottom'
		CARGO='bottom'
		DNF_COPR='atim/bottom'
		EMERGE='sys-process/bottom'
		EOPKG='bottom'
		NIX='bottom'
		PORT='bottom'
		SCOOP='bottom'
		WINGET='bottom'
	)
	if ! is-system --almalinux; then
		# almalinux is not aware of the DNF package
		util_options+=(DNF='bottom')
	fi

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='ClementTsang/bottom' glob='btm' arch
	arch="$(__get_arch)"
	if __is_macos; then
		__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_x86_64-apple-darwin.tar.gz' "$glob" || :
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_aarch64-unknown-linux-gnu.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_armv7-unknown-linux-gnu.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_i686-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'r64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_riscv64gc-unknown-linux-gnu.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_bottom "$@"
fi
