#!/usr/bin/env bash

# https://github.com/veeso/termscp
# https://termscp.veeso.dev/get-started.html

# https://github.com/veeso/termscp/releases
# termscp-v0.16.1-aarch4-apple-darwin.tar.gz
# termscp-v0.16.1-arm64-apple-darwin.tar.gz
# termscp-v0.16.1-x86_64-apple-darwin.tar.gz
# termscp-v0.16.1-x86_64-pc-windows-msvc.zip
# termscp-v0.16.1-x86_64-unknown-linux-gnu.tar.gz
# termscp.0.16.1.nupkg
# termscp_0.16.1_amd64.deb
# termscp_0.16.1_arm64.deb

function setup_util_termscp() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='termscp'
		BREW='veeso/termscp/termscp'
		CARGO='termscp'
		PACMAN='termscp'
		PKGIN='termscp'
		SCOOP='termscp'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='veeso/termscp' glob='bin/termscp' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-arm64-apple-darwin.tar.gz' "$glob" || :
			# strangely, there is a aarch4 and arm64 build for macos: https://github.com/veeso/termscp/issues/315#issuecomment-2645840568
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			# strangely, no tar build for arm64: https://github.com/veeso/termscp/issues/315#issuecomment-2645840568
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_arm64.deb' || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_amd64.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-gnu.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_termscp "$@"
fi
