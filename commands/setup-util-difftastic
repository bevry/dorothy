#!/usr/bin/env bash

# https://difftastic.wilfred.me.uk
# https://github.com/Wilfred/difftastic

# https://github.com/Wilfred/difftastic/releases/tag/0.62.0
# difft-aarch64-apple-darwin.tar.gz
# difft-aarch64-unknown-linux-gnu.tar.gz
# difft-x86_64-apple-darwin.tar.gz
# difft-x86_64-pc-windows-msvc.zip
# difft-x86_64-unknown-linux-gnu.tar.gz

# https://repology.org/project/difftastic/versions

function setup_util_difftastic() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='difft' # another project that uses a different cli from its name, promoting conflicts
		APK='difftastic'
		AUr='difftastic'
		EMERGE='dev-util/difftastic'
		NIX='difftastic'
		RPM='rust-difftastic'
		SCOOP='difftastic'
		WINGET='difftastic'
		XBPS='difftastic'
		ZYPPER='difftastic'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='Wilfred/difftastic' glob='difft' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-apple-darwin.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-unknown-linux-gnu.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-gnu.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_difftastic "$@"
fi
