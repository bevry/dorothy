#!/usr/bin/env bash

# https://micro-editor.github.io
# https://github.com/zyedidia/micro

# https://github.com/zyedidia/micro/releases
# micro-2.0.11-amd64.deb
# micro-2.0.11-freebsd32.tar.gz
# micro-2.0.11-freebsd64.tar.gz
# micro-2.0.11-linux-arm.tar.gz
# micro-2.0.11-linux-arm64.tar.gz
# micro-2.0.11-linux32.tar.gz
# micro-2.0.11-linux64-static.tar.gz
# micro-2.0.11-linux64.tar.gz
# micro-2.0.11-macos-arm64.tar.gz
# micro-2.0.11-netbsd32.tar.gz
# micro-2.0.11-netbsd64.tar.gz
# micro-2.0.11-openbsd32.tar.gz
# micro-2.0.11-openbsd64.tar.gz
# micro-2.0.11-osx.tar.gz
# micro-2.0.11-win32.zip
# micro-2.0.11-win64.zip

# @todo support bsd

# https://packages.debian.org/sid/amd64/micro/filelist
# /usr/bin/micro

function setup_util_micro() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='micro'
		# no apk, zypper
		APT='micro'
		AUR='micro'
		BREW='micro'
		BSD='micro'
		EOPKG='micro'
		INSTALLER='https://getmic.ro'
		PORT='micro'
		RPM='micro'
		SCOOP='micro'
		SNAP='micro --classic'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='zyedidia/micro' glob='*/micro' arch
	arch="$(__get_arch)"
	if __is_macos; then
		__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-osx.tar.gz' "$glob" || :
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux-arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux-arm.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			add_deb_option '-amd64.deb'
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux64.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux32.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_micro "$@"
fi
