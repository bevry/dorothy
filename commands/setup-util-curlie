# https://repology.org/project/curlie/versions

function setup_util_curlie() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='curlie'
		# despite docs, no apk
		AUR='curlie'
		BREW='curlie'
		EMERGE='net-misc/curlie'
		GO='github.com/rs/curlie'
		NIX='curlie'
		PKG='curlie'
		PORT='curlie'
		SCOOP='curlie'
		ZYPPER='curlie'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='rs/curlie' glob='curlie' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_darwin_arm64.tar.gz' "$glob" || :
		else
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_darwin_amd64.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_arm64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_arm64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_armv7.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_armv7.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_armv7.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_2_linux_amd64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_2_linux_amd64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_2_linux_amd64.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_386.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_386.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_386.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_curlie "$@"
fi
