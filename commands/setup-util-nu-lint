#!/usr/bin/env bash

# https://github.com/wvhulle/nu-lint

function setup_util_nu_lint() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Nu-Lint'
		--cli='nu-lint'
		CARGO='nu-lint'
	)
	setup-util "${util_options[@]}" "${user_options[@]}" || return $?
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_nu_lint "$@"
fi
