#!/usr/bin/env bash

# https://github.com/greymd/teip
# cut alternative

# https://github.com/greymd/teip/releases
# teip-2.3.2.aarch64-apple-darwin.tar.gz
# teip-2.3.2.aarch64-unknown-linux-musl.deb
# teip-2.3.2.aarch64-unknown-linux-musl.rpm
# teip-2.3.2.aarch64-unknown-linux-musl.tar.gz
# teip-2.3.2.arm-unknown-linux-gnueabihf.deb
# teip-2.3.2.arm-unknown-linux-gnueabihf.tar.gz
# teip-2.3.2.x86_64-apple-darwin.tar.gz
# teip-2.3.2.x86_64-unknown-linux-musl.deb
# teip-2.3.2.x86_64-unknown-linux-musl.rpm
# teip-2.3.2.x86_64-unknown-linux-musl.tar.gz
# teip_installer-2.3.2-x86_64-pc-windows-msvc.exe

# arm64
# https://github.com/greymd/teip/issues/23

# https://repology.org/project/teip/versions

function setup_util_teip() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='teip'
		# aur is outdated
		BREW='greymd/tools/teip'
		CARGO='teip'
		NIX='teip'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='greymd/teip'  glob='bin/teip' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.aarch64-apple-darwin.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.x86_64-apple-darwin.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '.aarch64-unknown-linux-musl.rpm' || :
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '.aarch64-unknown-linux-musl.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.aarch64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '.arm-unknown-linux-gnueabihf.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.arm-unknown-linux-gnueabihf.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '.x86_64-unknown-linux-musl.rpm' || :
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '.x86_64-unknown-linux-musl.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_teip "$@"
fi
