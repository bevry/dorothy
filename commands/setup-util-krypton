#!/usr/bin/env bash

function setup_util_krypton() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Krypton'
		--cli='krgpg'
		INSTALLER='https://krypt.co/kr'
	)
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_krypton "$@"
fi
