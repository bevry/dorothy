#!/usr/bin/env bash

# https://github.com/sharkdp/hyperfine
# benchmarking

# https://github.com/sharkdp/hyperfine/releases
# hyperfine-musl_1.17.0_amd64.deb
# hyperfine-musl_1.17.0_i686.deb
# hyperfine-v1.17.0-aarch64-unknown-linux-gnu.tar.gz
# hyperfine-v1.17.0-arm-unknown-linux-gnueabihf.tar.gz
# hyperfine-v1.17.0-arm-unknown-linux-musleabihf.tar.gz
# hyperfine-v1.17.0-i686-pc-windows-msvc.zip
# hyperfine-v1.17.0-i686-unknown-linux-gnu.tar.gz
# hyperfine-v1.17.0-i686-unknown-linux-musl.tar.gz
# hyperfine-v1.17.0-x86_64-apple-darwin.tar.gz
# hyperfine-v1.17.0-x86_64-pc-windows-gnu.zip
# hyperfine-v1.17.0-x86_64-pc-windows-msvc.zip
# hyperfine-v1.17.0-x86_64-unknown-linux-gnu.tar.gz
# hyperfine-v1.17.0-x86_64-unknown-linux-musl.tar.gz
# hyperfine_1.17.0_amd64.deb
# hyperfine_1.17.0_arm64.deb
# hyperfine_1.17.0_armhf.deb
# hyperfine_1.17.0_i686.deb

# https://packages.debian.org/sid/amd64/hyperfine/filelist
# /usr/bin/hyperfine

function setup_util_hyperfine() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='hyperfine'
		APK='hyperfine'
		AUR='hyperfine'
		BREW='hyperfine'
		BSD='hyperfine'
		CARGO='hyperfine'
		CONDA_CHANNEL='conda-forge'
		CONDA='hyperfine'
		NIX='hyperfine'
		PORT='hyperfine'
		RPM='hyperfine'
		XBPS='hyperfine'
		ZYPPER='hyperfine'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='sharkdp/hyperfine' glob='*/hyperfine' arch
	arch="$(__get_arch)"
	if __is_macos; then
		__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' "$glob" || :
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_arm64.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-unknown-linux-gnu.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_armhf.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-arm-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_amd64.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_i686.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-i686-unknown-linux-musl.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_hyperfine "$@"
fi
