# croc_v10.2.1_Windows7-64bit.zip

# https://repology.org/project/croc/versions

function setup_util_croc() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='croc'
		--cli='croc'
		BREW='croc'
		CONDA_CHANNEL='conda-forge'
		CONDA='croc'
		EMERGE='croc'
		GO='github.com/schollz/croc/v10@latest'
		NIX='croc'
		PACMAN='croc'
		PORT='croc'
		SCOOP='croc'
		WINGET='schollz.croc'
	)
	if ! is-system --almalinux; then
		# almalinux is not aware of the DNF package
		util_options+=(DNF='croc')
	fi

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='schollz/croc' glob='croc' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__get_github_asset_url_via_slug_regexp "$slug" '_macOS-ARM64.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__get_github_asset_url_via_slug_regexp "$slug" '_macOS-64bit.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__get_github_asset_url_via_slug_regexp "$slug" '_Linux-ARM64.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__get_github_asset_url_via_slug_regexp "$slug" '-ARM.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__get_github_asset_url_via_slug_regexp "$slug" '_Linux-64bit.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__get_github_asset_url_via_slug_regexp "$slug" '_Linux-32bit.tar.gz' "$glob" || :
		fi
	fi
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_croc "$@"
fi
