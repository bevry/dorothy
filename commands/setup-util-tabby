# not on repology

function setup_util_tabby() (
	source "$DOROTHY/sources/bash.bash"
	util_options=(
		--app='Tabby'
	)

	# fetch and use configuration
	if __is_windows; then
		util_options+=(
			SCOOP_BUCKET='extras'
			SCOOP='tabby'
			WINGET='Eugeny.Tabby'
		)
	else
		util_options+=(
			CASK='tabby'
		)

		# improve performance for detectable utilities when fetching asset configuration
		if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
			return 0
		fi

		# fetch and use configuration
		local slug='Eugeny/tabby' arch
		arch="$(__get_arch)"
		if __is_macos; then
			if [[ $arch == 'a64' ]]; then
				__fetch_and_add_dmg_option_via_slug_suffix_glob_filename "$slug" '-macos-arm64.dmg' '*/Tabby.app' 'Tabby.app' || :
			elif [[ $arch == 'x64' ]]; then
				__fetch_and_add_dmg_option_via_slug_suffix_glob_filename "$slug" '-macos-x86_64.dmg' '*/Tabby.app' 'Tabby.app' || :
			fi
		elif __is_linux; then
			if [[ $arch == 'a64' ]]; then
				__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-arm64.deb' || :
				__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-arm64.rpm' || :
				__fetch_and_add_appimage_option_via_slug_suffix "$slug" '-linux-arm64.AppImage' || :
			elif [[ $arch == 'a32' ]]; then
				__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-armv7l.deb' || :
				__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-armv7l.rpm' || :
				__fetch_and_add_appimage_option_via_slug_suffix "$slug" '-linux-armv7l.AppImage' || :
			elif [[ $arch == 'x64' ]]; then
				__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-x64.deb' || :
				__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-x64.rpm' || :
				__fetch_and_add_appimage_option_via_slug_suffix "$slug" '-linux-x64.AppImage' || :
			fi
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_tabby "$@"
fi
