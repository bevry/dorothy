#!/usr/bin/env bash

# https://www.beeper.com/download

# https://repology.org/project/beeper/versions

function setup_util_beeper() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Beeper'
		--app='Beeper'      # macos, appimage
		--app='beepertexts' # .desktop
	)

	# fetch and use configuration
	if __is_windows; then
		util_options+=(
			WINGET='Beeper.Beeper'
		)
	else
		util_options+=(
			AUR='beeper-v4-bin'
			CASK='beeper'
			EMERGE='net-im/beeper'
		)

		# fetch and use configuration
		if __is_macos; then
			__add_download_option_via_url 'https://api.beeper.com/desktop/download/macos/x64/stable/com.automattic.beeper.desktop' || :
		elif __is_linux; then
			local arch
			arch="$(__get_arch)"
			if [[ $arch == 'a64' ]]; then
				__add_appimage_option_via_url 'https://api.beeper.com/desktop/download/linux/arm64/stable/com.automattic.beeper.desktop' || :
			elif [[ $arch == 'x64' ]]; then
				__add_appimage_option_via_url 'https://api.beeper.com/desktop/download/linux/x64/stable/com.automattic.beeper.desktop' || :
			fi
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_beeper "$@"
fi
