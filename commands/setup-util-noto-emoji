#!/usr/bin/env bash

# https://github.com/googlefonts/noto-emoji/releases

function setup_util_noto_emoji() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Noto Emoji'
		--font='NotoColorEmoji.ttf'
		CASK='font-noto-emoji'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	__fetch_and_add_download_option_via_slug_pathname 'googlefonts/noto-emoji' 'fonts/NotoColorEmoji.ttf' || return $?

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_noto_emoji "$@"
fi
