#!/usr/bin/env bash

function echo_ordinal_test() (
	source "$DOROTHY/sources/bash.bash"
	eval-tester --ignore-stderr --status=22 -- echo-ordinal --help
)

function echo_ordinal() (
	source "$DOROTHY/sources/stdinargs.bash"

	# =====================================
	# Arguments

	function help {
		__print_help "$@" <<-EOF || return $?
			ABOUT:
			Convert numbers to ordinal form (1→1st, 2→2nd, 3→3rd, etc).

			USAGE:
			\`echo-ordinal [...options] [--] ...<number>\`
			\`echo-lines ...<number> | echo-ordinal [...options]\`

			OPTIONS:
			$(__stdinargs__help_options --)

			EXAMPLES:
			\`\`\`
			echo-ordinal -- 1 2 3 4 11 12 13 21 22 23
			echo-lines -- 1 2 3 4 11 12 13 21 22 23 | echo-ordinal
			\`\`\`
			Outputs:
			\`\`\`
			1st
			2nd
			3rd
			4th
			11th
			12th
			13th
			21st
			22nd
			23rd
			\`\`\`
			Returns: [0]
		EOF
		return 22 # EINVAL 22 Invalid argument
	}

	# =====================================
	# Action

	function __on_piece {
		local number="$1"
		local suffix

		# Handle teen numbers (11-13)
		case $((number % 100)) in
			11|12|13)
				suffix='th'
				;;
			*)
				# Handle other numbers based on last digit
				case $((number % 10)) in
					1)
						suffix='st'
						;;
					2)
						suffix='nd'
						;;
					3)
						suffix='rd'
						;;
					*)
						suffix='th'
						;;
				esac
				;;
		esac

		printf '%s%s\n' "$number" "$suffix"
	}

	stdinargs "$@"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	if [[ $* == '--test' ]]; then
		echo_ordinal_test
	else
		echo_ordinal "$@"
	fi
fi
