#!/usr/bin/env bash

# @todo merge into `setup-util-brew`

function setup_mac_brew_test() (
	source "$DOROTHY/sources/bash.bash"
	eval-tester --ignore-stderr --status=22 -- setup-mac-brew --help
)

function setup_mac_brew() (
	source "$DOROTHY/sources/bash.bash"

	# =====================================
	# Configuration

	source "$DOROTHY/sources/config.sh"

	# environment provides:
	# HOMEBREW_PREFIX, HOMEBREW_CELLAR

	# setup.bash provides:
	local HOMEBREW_UNTAPS+=(
		# deprecated with homebrew v4
		# https://brew.sh/2023/02/16/homebrew-4.0.0/
		'homebrew/core'
		'homebrew/cask'
		# deprecated
		'caskroom/cask'       # replaced by 'homebrew/cask'
		'caskroom/fonts'      # replaced by 'homebrew/cask-fonts'
		'homebrew/cask-fonts' # fonts mainlined https://github.com/ryanoasis/nerd-fonts/issues/1635#issue-2296375213
		'Homebrew/homebrew-cask-versions'
		'Homebrew/homebrew-services'
	)
	local HOMEBREW_TAPS=()
	local HOMEBREW_FORMULAS=()
	local HOMEBREW_SLOW_FORMULAS=()
	local HOMEBREW_CASKS=()
	local HOMEBREW_FONTS=()
	local HOMEBREW_UNINSTALL=()          # for casks and formulas
	local HOMEBREW_ENCODING_INSTALL=''   # '', 'yes', 'no'
	local HOMEBREW_ENCODING_REINSTALL='' # '', 'yes', 'no'
	local HOMEBREW_ENCODING_FORMULAS=(
		# https://github.com/homebrew-ffmpeg/homebrew-ffmpeg#included-libraries
		# only need to the list the ones that need special treatment
		# Warning: No available formula with the name "libflite".
		amiaopensource/amiaos/decklinksdk
		chromaprint
		lescanauxdiscrets/tap/zvbi
	)
	local HOMEBREW_ENCODING_REMOVE_OPTIONS=(
		# Resolved: https://github.com/homebrew-ffmpeg/homebrew-ffmpeg/issues/81#issuecomment-828722622
		# Fails: https://github.com/homebrew-ffmpeg/homebrew-ffmpeg/issues/96#issuecomment-1398315717
		--with-librsvg
		# Fails: https://github.com/homebrew-ffmpeg/homebrew-ffmpeg/issues/92
		--with-decklink
		# Fails: https://github.com/homebrew-ffmpeg/homebrew-ffmpeg/issues/37#issuecomment-958018136
		--with-game-music-emu
		# Fails: Error: An exception occurred within a child process: FormulaUnavailableError: No available formula with the name "zvbi".
		--with-libzvbi
		# Fails: ERROR: libflite not found
		--with-libflite
		# Fails: Unknown option "--enable-openvino".
		--enable-openvino
		--with-openvino
	)
	# Deprecated configurations:
	local SETUP_UTILS=()               # for configuration adjustments
	local HOMEBREW_INSTALL_ENCODING='' # deprecated, replaced by HOMEBREW_ENCODING_INSTALL
	local HOMEBREW_INSTALL=()          # deprecated, replaced by HOMEBREW_FORMULAS
	local HOMEBREW_INSTALL_SLOW=()     # deprecated, replaced by HOMEBREW_SLOW_FORMULAS
	local HOMEBREW_INSTALL_CASK=()     # deprecated, replaced by HOMEBREW_CASKS
	load_dorothy_config 'setup.bash'

	# add essentials
	HOMEBREW_TAPS+=(
		# the ffmpeg tap includes all the options, and is used later
		# https://github.com/homebrew-ffmpeg/homebrew-ffmpeg
		# https://trac.ffmpeg.org/wiki/CompilationGuide/macOS#Additionaloptions
		'homebrew-ffmpeg/ffmpeg'
	)

	# adjustments
	if [[ -z $HOMEBREW_ENCODING_INSTALL ]]; then
		HOMEBREW_ENCODING_INSTALL='no'
	fi
	if [[ -z $HOMEBREW_ENCODING_REINSTALL ]]; then
		HOMEBREW_ENCODING_REINSTALL='no'
	fi

	# deprecations
	if [[ -n $HOMEBREW_INSTALL_ENCODING ]]; then
		HOMEBREW_ENCODING_INSTALL="$HOMEBREW_INSTALL_ENCODING"
	fi
	HOMEBREW_FORMULAS+=("${HOMEBREW_INSTALL[@]}")
	HOMEBREW_SLOW_FORMULAS+=("${HOMEBREW_INSTALL_SLOW[@]}")
	HOMEBREW_CASKS+=("${HOMEBREW_INSTALL_CASK[@]}")
	if [[ ${#HOMEBREW_FORMULAS[@]} -ne 0 ]]; then
		__split --target={HOMEBREW_FORMULAS} --no-zero-length --invoke -- \
			dorothy-config --packages-var='HOMEBREW_FORMULAS' -- "${HOMEBREW_FORMULAS[@]}"
	fi
	if [[ ${#HOMEBREW_CASKS[@]} -ne 0 ]]; then
		__split --target={HOMEBREW_CASKS} --no-zero-length --invoke -- \
			dorothy-config --packages-var='HOMEBREW_CASKS' -- "${HOMEBREW_CASKS[@]}"
	fi

	# check if ffmpeg was mentioned, if it was, trim it and enable encoding tools
	local i item
	for i in "${!HOMEBREW_FORMULAS[@]}"; do
		item="${HOMEBREW_FORMULAS[i]}"
		if [[ $item == *'ffmpeg'* ]]; then
			HOMEBREW_FORMULAS[i]=''
			HOMEBREW_ENCODING_INSTALL='yes'
		fi
	done
	for i in "${!HOMEBREW_SLOW_FORMULAS[@]}"; do
		item="${HOMEBREW_SLOW_FORMULAS[i]}"
		if [[ $item == *'ffmpeg'* ]]; then
			HOMEBREW_SLOW_FORMULAS[i]=''
			HOMEBREW_ENCODING_INSTALL='yes'
		fi
	done

	# Remove problematic dependencies that routinely fail due to their circular nature
	# HOMEBREW_UNINSTALL+=(
	# 	chromaprint
	# 	homebrew-ffmpeg/ffmpeg/ffmpeg
	# 	ffmpeg
	# 	vim
	# 	python
	# 	ruby
	# )
	# fs-remove --quiet --no-confirm --optional -- "/Users/$(whoami)/Library/Python/"* "${HOMEBREW_CELLAR}/python"* "${HOMEBREW_PREFIX}/opt/python"*
	# brew install python # reinstall python now that it has been cleaned

	# =====================================
	# Arguments

	function __help {
		__print_help "$@" <<-EOF || return $?
			ABOUT:
			Setup Homebrew on your macOS machine, with automations for all your preferences.

			USAGE:
			\`setup-mac-brew [...options] <action> -- [...args]\`

			OPTIONS:
			--configure
			    When in <install> or <update> mode, reconfigure your Homebrew automations.

			--encoding
			    When in <install> mode, install encoding tools.

			ACTIONS:
			& install
			    Installs/updates everything, including prompts for casks.

			& update
			    Installs most things, updates everything, excludes prompts for casks.

			& clean
			    Cleanup the brew installation, such as removing caches and adjusting permissions.

			& uninstall
			    Completely remove Homebrew from the system. This will require a reload of your terminal once completed.
		EOF
		return 22 # EINVAL 22 Invalid argument
	}

	# process
	local item action='' option_configure='no'
	while [[ $# -ne 0 ]]; do
		item="$1"
		shift
		case "$item" in
		'--help' | '-h') __help ;;
		'--no-encoding'* | '--encoding'*) __flag --source={item} --target={HOMEBREW_ENCODING_INSTALL} --affirmative ;;
		'--no-configure'* | '--configure'*) __flag --source={item} --target={option_configure} --affirmative ;;
		'--'*) __help 'An unrecognised flag was provided: ' --variable-value={item} ;;
		*)
			if [[ -z $action ]]; then
				action="$item"
			else
				__help 'An unrecognised argument was provided: ' --variable-value={item}
			fi
			;;
		esac
	done

	# assert compatibility
	if ! __is_macos; then
		__help 'This command is only purposeful on macOS, which you are not running.' || :
		return 46 # EPFNOSUPPORT 46 Protocol family not supported
	fi

	# ensure valid action
	action="$(
		choose --required \
			--question='What action to perform?' \
			--skip-default --default="$action" -- install update clean uninstall
	)"

	# =====================================
	# Action Helpers

	# clean brew caches
	function __clean_brew {
		local -i clean_exit_status=0
		__print_style --h2='Cleanup Homebrew' || return $?
		if __is_brew; then
			# fix common permission errors
			# Error: Could not cleanup old kegs! Fix your permissions on:
			# /usr/local/Cellar/go/1.17.2
			if [[ -n ${HOMEBREW_CELLAR-} ]]; then
				if [[ -d "$HOMEBREW_CELLAR/go" ]]; then
					fs-own --ugx -- "$HOMEBREW_CELLAR/go" || clean_exit_status=$?
					# bin, libexec, and many other directories contain executables, so just make it all executable
				fi
			fi
			if [[ -d "$HOME/Library/Caches/go-build" ]]; then
				fs-own --elevate --ugx -- "$HOME/Library/Caches/go-build" || clean_exit_status=$?
				# fix: go: unlinkat /Users/balupton/Library/Caches/go-build/01/0128314b8deff070ae65a398c7404f3988fc31b20cd934f950eee92284d36875-d: permission denied
			fi
			# cleanup
			eval-helper --quiet --wrap -- brew cleanup --quiet -s --prune=all || clean_exit_status=$?
			# cleanup further
			fs-remove --quiet --no-confirm -- "$(brew --cache)" || clean_exit_status=$?
		fi
		if [[ $clean_exit_status -eq 0 ]]; then
			__print_style --g2='Cleanup Homebrew' || return $?
		else
			__print_style --e2='Cleanup Homebrew' ' ' --status="$clean_exit_status" || return $?
			return "$clean_exit_status"
		fi
	}

	# proceed?
	function __proceed {
		local exit_status=$?
		if [[ $exit_status -ne 0 ]]; then
			if ! confirm --positive --ppid=$$ --linger -- 'Would you like to proceed?' "Homebrew reported failure exit status of $exit_status, however unless there is actually an error above that requires attention then you can proceed safely, as homebrew reports failure exit statuses even when they are merely recommendations, and such recommendations are typically already handled by Dorothy."; then
				return "$exit_status"
			fi
		fi
	}

	# install brew
	function __install_brew {
		if __is_brew; then
			return 0
		fi
		local -i install_exit_status=0
		__print_style --h2='Install Homebrew'
		setup-util-brew install --verbose || install_exit_status=$?
		source "$DOROTHY/sources/environment.sh" # child processes will also inherit these changes
		if [[ $install_exit_status -eq 0 ]]; then
			__print_style --g2='Install Homebrew' || return $?
		else
			__print_style --e2='Install Homebrew' ' ' --status="$install_exit_status" || return $?
			return "$install_exit_status"
		fi
	}

	# update brew
	function __update_brew {
		local -i update_exit_status=0
		__print_style --h2='Update Homebrew'
		brew update --quiet || update_exit_status=$?
		if [[ $update_exit_status -eq 0 ]]; then
			__print_style --g2='Update Homebrew' || return $?
		else
			__print_style --e2='Update Homebrew' ' ' --status="$update_exit_status" || return $?
			return "$update_exit_status"
		fi
	}

	# upgrade brew
	function __upgrade_brew {
		local -i upgrade_exit_status=0
		__print_style --h2='Upgrade Homebrew'
		brew upgrade || upgrade_exit_status=$? # don't use `--quiet` such that progress bars are visible, which is important on slow or unreliable internet connections that otherwise may think the operation has stalled
		if [[ $upgrade_exit_status -eq 0 ]]; then
			__print_style --g2='Upgrade Homebrew' || return $?
		else
			__print_style --e2='Upgrade Homebrew' ' ' --status="$upgrade_exit_status" || return $?
			return "$upgrade_exit_status"
		fi
	}

	# install build deps
	function __install_build_deps {
		local -i install_exit_status=0
		__print_style --h2='Install build dependencies'
		setup-util-devel --dependency || install_exit_status=$?
		if [[ $install_exit_status -eq 0 ]]; then
			__print_style --g2='Install build dependencies' || return $?
		else
			__print_style --e2='Install build dependencies' ' ' --status="$install_exit_status" || return $?
			return "$install_exit_status"
		fi
	}

	# install encoding tools
	function __uninstall_encoding {
		__brew_uninstall ffmpeg homebrew-ffmpeg/ffmpeg/ffmpeg || return $?
	}
	function __install_encoding {
		# encoding
		if [[ $action == 'install' ]]; then
			# determine full value for HOMEBREW_ENCODING_INSTALL
			if [[ -z $HOMEBREW_ENCODING_INSTALL || $option_configure == 'yes' ]]; then
				if confirm --linger --negative --ppid=$$ -- 'Do you want to (re-)install encoding tools?' 'Installing encoding tools can take a while...'; then
					HOMEBREW_ENCODING_INSTALL='yes'
				else
					HOMEBREW_ENCODING_INSTALL='no'
				fi
				# we don't want to trigger a full configure, when just this is missing
				if [[ $option_configure == 'no' ]]; then
					dorothy-config 'setup.bash' -- \
						--field='HOMEBREW_ENCODING_INSTALL' --value="$HOMEBREW_ENCODING_INSTALL" || return $?
				fi
			fi
		fi

		# if yes, then install the linting tools
		if [[ $HOMEBREW_ENCODING_INSTALL == 'yes' || $HOMEBREW_ENCODING_REINSTALL == 'yes' ]]; then
			__print_style \
				--h1='Homebrew encoding tools' --newline \
				--notice='This can take a while... ⏲' || return $?

			# install dependencies:
			# https://github.com/varenc/homebrew-ffmpeg/issues/28
			# https://trac.ffmpeg.org/wiki/CompilationGuide/macOS
			# @todo perhaps this entire encoding section can become modifiers to the existing operations
			__brew_install_fast "${HOMEBREW_ENCODING_FORMULAS[@]}" || return $?

			# Only reinstall if desired
			if [[ $HOMEBREW_ENCODING_REINSTALL == 'yes' ]] || ! command-working -- ffmpeg; then
				# Installing chromaprint will cause ffmpeg to be installed automatically, as such we need to remove that ffmpeg
				# so that we can install the one with the build options
				# Uninstall is necessary to prevent:
				#     Error: ffmpeg is already installed
				# --ignore-dependencies is necessary to prevent:
				#     Error: Refusing to uninstall because it is required by chromaprint, which is currently installed.
				#     Error: chromaprint not found
				# More details:
				# https://github.com/homebrew-ffmpeg/homebrew-ffmpeg/issues/13#issuecomment-647408007
				__uninstall_encoding || :

				# log
				__print_style --h2='Install ffmpeg with options' || return $?

				# fetch all possible build options for ffmpeg
				local options_for_ffmpeg=()
				__split --target={options_for_ffmpeg} --delimiter=' ' --no-zero-length --invoke -- \
					brew options homebrew-ffmpeg/ffmpeg/ffmpeg --compact || return $?

				# remove unwanted options that break the build
				__evict --source+target={options_string_for_ffmpeg} --optional --every -- \
					"${HOMEBREW_ENCODING_REMOVE_OPTIONS[@]}" || return $?

				# install with the build options
				eval-helper --quiet --wrap -- \
					brew install homebrew-ffmpeg/ffmpeg/ffmpeg "${options_for_ffmpeg[@]}" || return $?

				# log
				__print_style --g2='Install ffmpeg with options' || return $?
			fi

			# log
			__print_style --g1='Homebrew encoding tools' || return $?
		else
			__print_style --notice='Skipped encoding tools installation, due to preference.' || return $?
		fi
	}

	# install packages with brew
	# __brew_install [...<option>] -- ...<package>
	function __brew_install {
		local -i install_exit_status=0
		# extract brew options from arguments
		local options_for_brew=('--quiet')
		while [[ $# -gt 0 ]]; do
			if [[ $1 == '--' ]]; then
				shift
				break
			fi
			options_for_brew+=("$1")
			shift
		done
		# install
		local package packages_without_options=()
		for package in "$@"; do
			if [[ -z $package ]]; then
				# ffmpeg argument may be trimmed
				continue
			fi
			local arguments_for_package=()
			__split --source={package} --target={arguments_for_package} --delimiter=' ' --no-zero-length || return $?
			if [[ ${#arguments_for_package[@]} -eq 1 ]]; then
				# it doesn't have arguments, install it in bulk
				packages_without_options+=("$package")
			else
				# it has arguments, install it right now with the arguments
				eval-helper --quiet --wrap -- \
					brew install "${options_for_brew[@]}" "${arguments_for_package[@]}" || install_exit_status=$?
			fi
		done
		if [[ ${#packages_without_options[@]} -ne 0 ]]; then
			eval-helper --quiet --wrap -- \
				brew install "${options_for_brew[@]}" "${packages_without_options[@]}" || install_exit_status=$?
		fi
		return "$install_exit_status"
	}

	# install packages with brew, that are fast to install
	function __brew_install_fast {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		local -i install_exit_status=0
		__print_style --h2="Install $# formulas" || return $?
		__brew_install --formula -- "$@" || install_exit_status=$?
		if [[ $install_exit_status -eq 0 ]]; then
			__print_style --g2="Install $# formulas" || return $?
		else
			__print_style --e2="Install $# formulas" ' ' --status="$install_exit_status" || return $?
			return "$install_exit_status"
		fi
	}

	# install packages with brew, that are slow to install
	function __brew_install_slow {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		local -i install_exit_status=0
		# if we are on an official directory, then we are using bottles which are pre-compiled and fast
		if [[ $HOMEBREW_PREFIX == '/usr/local' || $HOMEBREW_PREFIX == '/opt/homebrew' ]]; then
			__print_style --h2="Install $# extra formulas" || return $?
			__brew_install --formula -- "$@" || install_exit_status=$?
			if [[ $install_exit_status -eq 0 ]]; then
				__print_style --g2="Install $# extra formulas" || return $?
			else
				__print_style --e2="Install $# extra formulas" || return $?
				return "$install_exit_status"
			fi
		else
			# otherwise we are on a custom directory, can't use bottles, so have to compile ourselves, which takes forever
			if confirm --linger --bool --ppid=$$ -- "Do you want to install [$*]?" 'These can take hours, so best left overnight...'; then
				__print_style --h2="Install $# slow formulas" --newline \
					--notice='This can take a while... ⏲' || return $?
				__brew_install --formula -- "$@" || install_exit_status=$?
				if [[ $install_exit_status -eq 0 ]]; then
					__print_style --g2="Install $# slow formulas" || return $?
				else
					__print_style --e2="Install $# slow formulas" ' ' --status="$install_exit_status" || return $?
					return "$install_exit_status"
				fi
			fi
		fi
	}

	# install fonts with brew
	function __brew_install_fonts {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		local -i install_exit_status=0
		__print_style --h2="Install $# fonts" || return $?
		__brew_install --cask -- "$@" || install_exit_status=$?
		if [[ $install_exit_status -eq 0 ]]; then
			__print_style --g2="Install $# fonts" || return $?
		else
			__print_style --e2="Install $# fonts" ' ' --status="$install_exit_status" || return $?
			return "$install_exit_status"
		fi
	}

	# install casks with brew
	function __brew_install_cask {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		local selection=()
		__split --target={selection} --no-zero-length --invoke -- \
			choose --default-all --multi --question='Which casks would you like to brew install?' -- "$@" || return $?
		local -i install_exit_status=0
		__print_style --h2="Install $# casks"
		__brew_install --cask -- "${selection[@]}" || install_exit_status=$?
		if [[ $install_exit_status -eq 0 ]]; then
			__print_style --g2="Install $# casks" || return $?
		else
			__print_style --e2="Install $# casks" ' ' --status="$install_exit_status" || return $?
			return "$install_exit_status"
		fi
	}

	# uninstall packages with brew
	function __brew_uninstall {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		local -i uninstall_exit_status=0
		__print_style --h2="Uninstall $# packages" || return $?
		if [[ $# -ne 0 ]]; then
			if brew-installed --quiet -- "$@"; then
				local package
				for package in "$@"; do
					if brew-installed --quiet -- "$package"; then
						eval-helper --quiet --wrap \
							--pending="$(__print_style --bold='Uninstalling: ' --code="$package")" \
							--success="$(__print_style --success='Uninstalled: ' --code="$package")" \
							--failure="$(__print_style --error='Failed to uninstall: ' --code="$package")" -- \
							brew uninstall --quiet --ignore-dependencies "$package" || uninstall_exit_status=$?
					fi
				done
				# cleanup, used to fix any breaks after the removals, this is only here are is purges upgrade caches, which is undesirable on unreliable internet connections as it means re-runs always has to download everything again
				source "$DOROTHY/sources/environment.sh"
				__clean_brew || return $?
			fi
		fi
		if [[ $uninstall_exit_status -eq 0 ]]; then
			__print_style --g2="Uninstall $# packages" || return $?
		else
			__print_style --e2="Uninstall $# packages" ' ' --status="$uninstall_exit_status" || return $?
			return "$uninstall_exit_status"
		fi
	}

	# untap repositories with brew
	function __brew_untap {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		local -i tap_exit_status=0
		local tap
		__print_style --h2="Untap $# repositories" || return $?
		if brew-installed --quiet --tap -- "$@"; then
			for tap in "$@"; do
				if brew-installed --quiet -- "$tap"; then
					eval-helper --quiet --wrap \
						--pending="$(__print_style --bold='Untapping: ' --code="$tap")" \
						--success="$(__print_style --success='Untapped: ' --code="$tap")" \
						--failure="$(__print_style --error='Failed to untap: ' --code="$tap")" -- \
						brew untap --quiet "$tap" || tap_exit_status=$?
				fi
			done
		fi
		if [[ $tap_exit_status -eq 0 ]]; then
			__print_style --g2="Untap $# repositories" || return $?
		else
			__print_style --e2="Untap $# repositories" ' ' --status="$tap_exit_status" || return $?
			return "$tap_exit_status"
		fi
	}

	# tap repositories with brew
	function __brew_tap {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		local -i tap_exit_status=0
		local tap
		__print_style --h2="Tap $# repositories" || return $?
		for tap in "$@"; do
			eval-helper --quiet --wrap \
				--pending="$(__print_style --bold='Tap: ' --code="$tap")" \
				--success="$(__print_style --success='Tapped: ' --code="$tap")" \
				--failure="$(__print_style --error='Failed to tap: ' --code="$tap")" -- \
				brew tap --quiet "$tap" || tap_exit_status=$?
		done
		if [[ $tap_exit_status -eq 0 ]]; then
			__print_style --g2="Tap $# repositories" || return $?
		else
			__print_style --e2="Tap $# repositories" ' ' --status="$tap_exit_status" || return $?
			return "$tap_exit_status"
		fi
	}

	# update repositories
	function __brew_update_repo {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		local -i repo_exit_status=0
		local repo
		__print_style --h2="Update $# repositories" || return $?
		for repo in "$@"; do
			# Unshallow fixes:
			# https://github.com/Homebrew/brew/pull/9383
			# ^ fix: Error: homebrew-cask is a shallow clone
			# ^ github requested initial clones be shallow, however initial clones cannot be updated
			# ^ as such we have to unshallow the repo
			# ^ however, `git fetch --unshallow` will fail if already not shallow
			# ^ as such, detect accordingly
			# https://stackoverflow.com/a/37533086/130638
			# eval-helper --quiet --wrap \
			# 	--pending="$(__print_style --bold='Updating: ' --path="$repo")" \
			# 	--success="$(__print_style --success='Updated: ' --path="$repo")" \
			# 	--failure="$(__print_style --error='Failed to update: ' --path="$repo")" -- \
			git-helper sync --unshallow --path="$repo" || repo_exit_status=$?
		done
		if [[ $repo_exit_status -eq 0 ]]; then
			__print_style --g2="Update $# repositories" || return $?
		else
			__print_style --e2="Update $# repositories" ' ' --status="$repo_exit_status" || return $?
			return "$repo_exit_status"
		fi
	}

	# update taps, using the first passed one, to figure out all the rest
	function __brew_update_tap {
		if [[ $# -eq 0 ]]; then
			return 0
		fi
		# repositories
		local first_tap="$1" first_tap_repo_path casks_repo_path
		first_tap_repo_path="$(brew --repo "$first_tap")" || return $?
		casks_repo_path="$(fs-path --parents -- "$first_tap_repo_path")" || return $?
		if [[ $first_tap == */* ]]; then
			# homebrew-ffmpeg/ffmpeg => /opt/homebrew/Library/Taps/homebrew-ffmpeg/homebrew-ffmpeg => /opt/homebrew/Library/Taps
			casks_repo_path="$(fs-path --parents -- "$casks_repo_path")" || return $?
		fi
		local repo_paths=()
		__split --target={repo_paths} --no-zero-length --invoke -- \
			echo-subpaths -- "$casks_repo_path" || return $?
		__brew_update_repo "${repo_paths[@]}" || return $?
	}

	# =====================================
	# Actions

	# action: clean then exit
	if [[ $action == 'clean' ]]; then
		__clean_brew || return $?
		return $?
	fi

	# action: uninstall then exit
	if [[ $action == 'uninstall' ]]; then
		__print_style --h1='Uninstall Homebrew'
		setup-util-brew uninstall --verbose
		return $?
	fi

	# log
	local action_title
	action_title="$(__get_uppercase_first_letter "$action")"
	action_title="Setup/${action_title} Homebrew"
	__print_style --h1="$action_title"

	# ensure brew is installed
	__install_brew || return $?

	# taps
	__brew_untap "${HOMEBREW_UNTAPS[@]}" || __proceed || return $?
	__brew_tap "${HOMEBREW_TAPS[@]}" || __proceed || return $?
	__brew_update_tap "${HOMEBREW_TAPS[@]}" || __proceed || return $?

	# update
	__update_brew || __proceed || return $?

	# uninstall packages
	__brew_uninstall "${HOMEBREW_UNINSTALL[@]}" || __proceed || return $?

	# uninstall encoding tools
	# this is necessary before updates, as it could update to a broken update
	# as such, uninstall before updates, so we can reinstall with our workarounds after
	if [[ $HOMEBREW_ENCODING_REINSTALL == 'yes' ]] || ([[ $HOMEBREW_ENCODING_INSTALL == 'yes' ]] && ! command-working -- ffmpeg); then
		__uninstall_encoding || __proceed || return $?
	fi

	# update packages
	__upgrade_brew || __proceed || return $?

	# dependencies
	__install_build_deps || __proceed || return $?

	# install encoding tools
	__install_encoding || __proceed || return $?

	# install (fast/default) formulas
	__brew_install_fast "${HOMEBREW_FORMULAS[@]}" || __proceed || return $?

	# install slow formulas
	__brew_install_slow "${HOMEBREW_SLOW_FORMULAS[@]}" || __proceed || return $?

	if [[ $action == 'install' ]]; then
		# install casks
		__brew_install_cask "${HOMEBREW_CASKS[@]}" || __proceed || return $?

		# install fonts
		__brew_install_fonts "${HOMEBREW_FONTS[@]}" || __proceed || return $?
	fi

	# -------------------------------------
	# Reconfigure?

	if [[ $option_configure != 'yes' ]]; then
		if [[ ${#HOMEBREW_FORMULAS[@]} -eq 0 ]]; then
			if confirm --positive --ppid=$$ -- 'You currently have no formula listed in your user configuration, do you want to update the configuration to reflect what you have installed?'; then
				option_configure='yes'
			fi
		fi
	fi

	if [[ $option_configure == 'yes' ]]; then
		# fetch what was installed by request
		local requested_formulas=() requested_cask=()
		__split --target={requested_formulas} --no-zero-length --invoke -- \
			brew-installed --requested --formula
		__split --target={requested_cask} --no-zero-length --invoke -- \
			brew-installed --requested --cask

		# because installation has completed, we can reset the config vars
		# this will also allow us to put everything in the right place
		HOMEBREW_FORMULAS=()
		HOMEBREW_FONTS=()
		HOMEBREW_CASKS=()
		# do not reset `SETUP_UTILS`, only add to it, as there isn't installed detection for it

		# update our listings appropriately
		local item installer
		for item in "${requested_formulas[@]}"; do
			installer="$(setup-util get-installer --quiet -- "$item" || :)"
			if [[ -n $installer ]]; then
				if [[ $installer == 'setup-util-'* ]]; then
					SETUP_UTILS+=("${installer#*setup-util-}")
				fi
				continue
			fi
			if __has --source={HOMEBREW_SLOW_FORMULAS} -- "$item"; then
				continue
			fi
			if __has --source={HOMEBREW_ENCODING_FORMULAS} -- "$item"; then
				continue
			fi
			if [[ $item == *'ffmpeg'* ]]; then
				# this is handled specially by encoding setup, in a special way that includes options
				continue
			fi
			HOMEBREW_FORMULAS+=("$item")
		done
		for item in "${requested_cask[@]}"; do
			installer="$(setup-util get-installer --quiet -- "$item" || :)"
			if [[ -n $installer ]]; then
				if [[ $installer == 'setup-util-'* ]]; then
					SETUP_UTILS+=("${installer:11}")
				fi
				continue
			fi
			if [[ $item == 'font-'* ]]; then
				HOMEBREW_FONTS+=("$item")
			else
				HOMEBREW_CASKS+=("$item")
			fi
		done

		# save
		__unique --source+target={SETUP_UTILS} --ignore-case || return $?
		dorothy-config 'setup.bash' -- \
			--field='SETUP_UTILS' --array="$(__print_lines "${SETUP_UTILS[@]}")" \
			--field='HOMEBREW_ENCODING_INSTALL' --value="$HOMEBREW_ENCODING_INSTALL" \
			--field='HOMEBREW_FORMULAS' --array="$(__print_lines "${HOMEBREW_FORMULAS[@]}")" \
			--field='HOMEBREW_CASKS' --array="$(__print_lines "${HOMEBREW_CASKS[@]}")" \
			--field='HOMEBREW_FONTS' --array="$(__print_lines "${HOMEBREW_FONTS[@]}")"
	fi

	# -------------------------------------
	# Finish

	# log
	__print_style --g1="$action_title"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	if [[ $1 == 'test' ]]; then
		setup_mac_brew_test "$@"
	else
		setup_mac_brew "$@"
	fi
fi
