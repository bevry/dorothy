#!/usr/bin/env bash

# https://github.com/eza-community/eza
# ls alternative

# https://github.com/eza-community/eza/releases

# https://repology.org/project/eza/versions

function setup_util_eza() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='eza'
		# despite docs, no apk
		APT_KEY='https://raw.githubusercontent.com/eza-community/eza/main/deb.asc'
		APT_REPO='deb [arch={ARCH} signed-by={KEY}] https://deb.gierens.de stable main'
		APT='eza'
		AUR='eza'
		BREW='eza'
		CARGO='eza'
		NIX='eza' NIX_PROFILE='nixpkgs#eza'
		PORT='eza'
		SCOOP='eza'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local eza='eza-community/eza' glob='eza' arch
	arch="$(__get_arch)"
	if __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" 'aarch64-unknown-linux-gnu.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" 'x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_eza "$@"
fi
