#!/usr/bin/env bash

# Git
# https://git-scm.com/download/linux
# https://packages.debian.org/sid/amd64/git/filelist
# /usr/bin/git
# /usr/bin/git-receive-pack
# /usr/bin/git-shell
# /usr/bin/git-upload-archive
# /usr/bin/git-upload-pack
# /usr/bin/scalar

function setup_util_git() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='git'
		--cli='git'
		APK='git'
		APT='git'
		AUR='git'
		BREW='git'
		BSD='git'
		EMERGE='dev-vcs/git'
		NIX='nixpkgs.git'
		RPM='git'
		URPMI='git'
		XBPS='git'
		ZYPPER='git-core'
	)
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_git "$@"
fi
