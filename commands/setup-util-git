#!/usr/bin/env bash

# Git
# https://git-scm.com/download/linux
# https://packages.debian.org/sid/amd64/git/filelist
# /usr/bin/git
# /usr/bin/git-receive-pack
# /usr/bin/git-shell
# /usr/bin/git-upload-archive
# /usr/bin/git-upload-pack
# /usr/bin/scalar

function setup_util_git() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='git'
		--cli='git'
		APK='git'
		APT='git'
		AUR='git'
		BREW='git'
		BSD='git'
		EMERGE='dev-vcs/git'
		NIX='nixpkgs.git'
		RPM='git'
		URPMI='git'
		XBPS='git'
		ZYPPER='git-core'
	)
	setup-util "${util_options[@]}" "${user_options[@]}"

	# @todo move all of these in `setup-git`

	# GPG
	setup-util-gpg "${user_options[@]}" --optional

	# https://en.wikipedia.org/wiki/OpenSSH
	setup-util-ssh "${user_options[@]}" --optional

	# Diff/Merge Tool: meld
	# setup-util-meld "${user_options[@]}" --optional
	# ^ does anyone use this?

	# Diff/Merge Tool: delta
	setup-util-delta "${user_options[@]}" --optional
	# ^ superior to delta

	# Diff/Merge Tool: diff
	setup-util-diff "${user_options[@]}" --optional

	# Git LFS
	setup-util-git-lfs "${user_options[@]}" --optional

	# Pinentry
	setup-util-pinentry "${user_options[@]}" --optional

	# ssh-askpass
	setup-util-ssh-askpass "${user_options[@]}" --optional

	# Gitell
	setup-util-gitell "${user_options[@]}" --optional
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_git "$@"
fi
