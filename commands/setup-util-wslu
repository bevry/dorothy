#!/usr/bin/env bash

# https://wslutiliti.es/wslu/
# https://wslutiliti.es/wslu/install.html

function setup_util_wslu() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='wslu'
		--cli='wslview'
		APK='wslu'
		APT_REPO='ppa:wslutilities/wslu'
		APT='wslu'
		BREW='wslu'
		RPM='wslu'
	)
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_wslu "$@"
fi
