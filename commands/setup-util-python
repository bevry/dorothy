#!/usr/bin/env bash

function setup_util_python() (
	source "$DOROTHY/sources/bash.bash"
	source "$(type -P setup-util)"
	util_options=(
		--name='Python'
		--configure-eval='python_configure'
		EVAL_INSTALL='__install'
		EVAL_UNINSTALL='__uninstall'
	)

	function python_configure {
		if [[ $SETUP_UTIL__INSTALLED == 'yes' && $SETUP_UTIL__EXTRA == 'yes' ]]; then
			source "$DOROTHY/sources/config.sh"

			# setup.bash provides:
			local PYTHON_INSTALL=()
			local PIP_INSTALL=()
			local PYTHON2_PIP_INSTALL=()
			local PYTHON3_PIP_INSTALL=()
			local PIPX_INSTALL=()
			local UV_INSTALL=()
			load_dorothy_config 'setup.bash'

			# deprecations
			# @todo update uv to also handle the PYTHON2 and PYTHON3 options, via PYTHON2_INSTALL and PYTHON3_INSTALL, or have UV_INSTALL include a python specifier
			local deprecations='no'
			if [[ ${#PIPX_INSTALL[@]} -ne 0 ]]; then
				__print_error 'Inside `setup.bash` user configuration, `PIPX_INSTALL` is deprecated, please use `PYTHON_INSTALL` or `UV_INSTALL` instead.' || return $?
				deprecations='yes'
			fi
			if [[ ${#PIP_INSTALL[@]} -ne 0 ]]; then
				__print_error 'Inside `setup.bash` user configuration, `PIP_INSTALL` is deprecated, please use `PYTHON_INSTALL` or `UV_INSTALL` instead.' || return $?
				deprecations='yes'
			fi
			if [[ ${#PYTHON2_PIP_INSTALL[@]} -ne 0 ]]; then
				__print_error 'Inside `setup.bash` user configuration, `PYTHON2_PIP_INSTALL` is deprecated, please use `PYTHON_INSTALL` or `UV_INSTALL` instead. Or send a PR for `PYTHON2_INSTALL` which uses UV in the background.' || return $?
				deprecations='yes'
			fi
			if [[ ${#PYTHON3_PIP_INSTALL[@]} -ne 0 ]]; then
				__print_error 'Inside `setup.bash` user configuration, `PYTHON3_PIP_INSTALL` is deprecated, please use `PYTHON_INSTALL` or `UV_INSTALL` instead.  Or send a PR for `PYTHON3_INSTALL` which uses UV in the background.' || return $?
				deprecations='yes'
			fi
			if [[ $deprecations == 'yes' ]]; then
				return 6 # ENXIO 6 Device not configured
			fi

			# adjustments
			__split --target={PYTHON_INSTALL} --no-zero-length --invoke -- \
				dorothy-config --packages-var='PYTHON_INSTALL' -- "${PYTHON_INSTALL[@]}" || return $?
			__split --target={UV_INSTALL} --no-zero-length --invoke -- \
				dorothy-config --packages-var='UV_INSTALL' -- "${UV_INSTALL[@]}" || return $?

			# there use to be support for `pip` and `pipx` here, but it was dropped, as `uv` is superior

			# packages
			local uv_install=("${UV_INSTALL[@]}" "${PYTHON_INSTALL[@]}")
			if [[ ${#uv_install[@]} -ne 0 ]]; then
				__print_style --h3="Install ${#uv_install[@]} uv packages" || return $?
				setup-util install --transpose=UV -- "${uv_install[@]}" || return $?
				__print_style --g3="Install ${#uv_install[@]} uv packages" || return $?
			fi
		fi
	}

	# helpers
	function __uninstall {
		local util_options=()
		local -i status=0

		# python2
		# homebrew no longer offers python2, their suggestion is to use pyenv instead
		# despite docs, apk does not offer python or python2
		util_options=(
			--uninstall
			--optional
			--cli='python2'
			APT='python2'
			AUR='python2'
			RPM='python'
			ZYPPER='python'
		)
		setup-util "${util_options[@]}" || status=$?

		# python3
		util_options=(
			--uninstall
			--cli='python3'
			APK='python3'
			APT='python3'
			AUR='python3'
			BREW='python3'
			RPM='python3'
			ZYPPER='python3'
		)
		setup-util "${util_options[@]}" || status=$?

		# dependencies for linux, not macos
		if __is_linux; then
			util_options=(
				--uninstall
				--optional
				--name='python3-venv'
				APT='python3-venv'
				AUR='python-virtualenv'
				ZYPPER='python3-virtualenv'
			)
			setup-util "${util_options[@]}" || status=$?
		fi

		# @todo consider whether to also call `setup-util-uv uninstall`

		# return failure status
		return "$status"
	}
	function __install {
		setup-util-uv "$@" || return $?
		uv python install || return $?
	}

	# setup
	setup_util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_python "$@"
fi
