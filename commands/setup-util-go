#!/usr/bin/env bash

# https://go.dev/doc/install
# https://go.dev/dl/

# https://github.com/golang/go/wiki/Ubuntu
# https://go.dev/wiki/Ubuntu

# https://repology.org/project/go/versions

function setup_util_go() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='go'
		--source='... apt'
		--dependencies=devel
		--configure-eval='__configure'
		# despite docs, no apk
		# snap is recommended over apt, so put apt last
		APK='go'
		APT_REPO='ppa:longsleep/golang-backports'
		APT='golang-go'
		AUR='go' # is `go` not `go-bin` as repology reports
		BREW='go'
		DNF='golang'
		GENTOO='dev-lang/go'
		MACPORTS='go'
		NIX='go'
		SCOOP='go'
		SNAP='go --classic'
		SUSE='go'
		VOID='go'
		WINGET='GoLang.Go'
	)
	function __configure {
		if [[ $SETUP_UTIL__EXTRA == 'yes' ]]; then
			source "$DOROTHY/sources/config.sh"

			# setup.bash provides:
			local GO_INSTALL=()
			local GO_LINTING_INSTALL='' # '', 'yes', 'no'
			load_dorothy_config 'setup.bash'

			# adjustments
			__split --target={GO_INSTALL} --no-zero-length --invoke -- \
				dorothy-config --packages-var='GO_INSTALL' -- "${GO_INSTALL[@]}"

			# determine full value for `GO_LINTING_INSTALL`
			local configure="$SETUP_UTIL__CONFIGURE"
			if [[ -z $GO_LINTING_INSTALL || $configure == 'yes' ]]; then
				configure='yes'
				if confirm --linger --negative --ppid=$$ -- "Do you also want to install go linting packages? This is desired if you plan to code with go."; then
					GO_LINTING_INSTALL='yes'
				else
					GO_LINTING_INSTALL='no'
				fi
			fi

			# if yes, then install the linting tools
			if [[ $GO_LINTING_INSTALL == 'yes' ]]; then
				if [[ $configure == 'yes' ]]; then
					dorothy-config 'setup.bash' -- \
						--field='GO_LINTING_INSTALL' --value="$GO_LINTING_INSTALL"
				fi
				setup-util-golint install
			fi

			# adjustments
			__split --target={CARGO_INSTALL} --no-zero-length --invoke -- \
				dorothy-config --packages-var='CARGO_INSTALL' -- "${CARGO_INSTALL[@]}"

			# packages
			setup-util install --transpose=GO -- "${GO_INSTALL[@]}"
		fi
	}

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}" || return $?
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_go "$@"
fi
