#!/usr/bin/env bash

# https://go.dev/doc/install
# https://go.dev/dl/

# https://github.com/golang/go/wiki/Ubuntu
# https://go.dev/wiki/Ubuntu

# https://repology.org/project/go/versions

function setup_util_go() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='go'
		--source='... apt'
		# despite docs, no apk
		# snap is recommended over apt, so put apt last
		APK='go'
		APT_REPO='ppa:longsleep/golang-backports'
		APT='golang-go'
		AUR='go' # is `go` not `go-bin` as repology reports
		BREW='go'
		DNF='golang'
		GENTOO='dev-lang/go'
		MACPORTS='go'
		NIX='go'
		SCOOP='go'
		SNAP='go --classic'
		SUSE='go'
		VOID='go'
		WINGET='GoLang.Go'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# deps, this is the reason we do the improve performance trick above
	setup-util-devel dependency

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}" || return $?
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_go "$@"
fi
