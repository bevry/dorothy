#!/usr/bin/env bash

# https://xon.sh/contents.html#installation

function setup_util_xonsh() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='xonsh'
		UV='xonsh --with prompt-toolkit'
	)
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_xonsh "$@"
fi
