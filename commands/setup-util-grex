#!/usr/bin/env bash

# https://github.com/pemistahl/grex
# regexp builder

# https://github.com/pemistahl/grex/releases
# grex-v1.4.2-aarch64-apple-darwin.tar.gz
# grex-v1.4.2-x86_64-apple-darwin.tar.gz
# grex-v1.4.2-x86_64-pc-windows-msvc.zip
# grex-v1.4.2-x86_64-unknown-linux-musl.tar.gz

function setup_util_grex() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='grex'
		BREW='grex'
		CARGO='grex'
		SCOOP='grex'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='pemistahl/grex' glob='grex' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-apple-darwin.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_grex "$@"
fi
