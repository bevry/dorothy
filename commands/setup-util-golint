function setup_util_golint() (
	source "$DOROTHY/sources/util.bash"

	# only install official linting tools
	# https://github.com/golang/vscode-go/blob/master/docs/tools.md

	# https://github.com/golang/tools/blob/master/gopls/README.md
	# _cgo_export.c:3:10: fatal error: 'stdlib.h' file not found
	util_options=(
		--cli='gopls'
		--dependency=devel
		GO='golang.org/x/tools/gopls'
	)
	setup-util "${util_options[@]}" "${setup_options[@]}"

	# https://github.com/go-delve/delve/tree/master/Documentation/installation
	# _cgo_export.c:3:10: fatal error: 'stdlib.h' file not found
	util_options=(
		--name='Delve'
		--cli='dlv'
		GO='github.com/go-delve/delve/cmd/dlv'
	)
	setup-util "${util_options[@]}" "${setup_options[@]}"

	# golangci-lint
	local slug='golangci/golangci-lint' glob='golangci-lint' arch
	arch="$(__get_arch)"
	util_options=(
		--cli='golangci-lint'
		BREW='golangci-lint'
	)
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-darwin-arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-darwin-amd64.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-arm64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-arm64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux-arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-armv7.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-armv7.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux-armv7.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-amd64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-amd64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux-amd64.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-386.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-386.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux-386.tar.gz' "$glob" || :
		elif [[ $arch == 'r64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-riscv64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-riscv64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-linux-riscv64.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_golint "$@"
fi
