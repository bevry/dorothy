#!/usr/bin/env bash

# https://en.wikipedia.org/wiki/Vim_(text_editor)

# https://www.digitalocean.com/community/tutorials/installing-and-using-the-vim-text-editor-on-a-cloud-server

# https://packages.debian.org/sid/amd64/vim/filelist
# /usr/bin/vim.basic

function setup_util_vim() (
	source "$DOROTHY/sources/util.bash"
	source "$(type -P setup-util)" # enable *_EVAL
	util_options=(
		--name='Vim (Vi IMproved)'
		--cli='vim'
		APK='vim'
		APT='vim'
		AUR='vim'
		BREW='vim'
		RPM='vim'
		ZYPPER='vim'
		RECONFIGURE_INSTALLED_EVAL='__reconfigure'
	)
	function __reconfigure {
		# ensure vim configuration
		if is-missing -- "$HOME/.vimrc"; then
			__print_style 'Vim configuration missing, applying the fancy defaults from:' --newline --url='https://github.com/amix/vimrc' || return $?
			github-download \
				--slug='amix/vimrc' \
				--head \
				--pathname='vimrcs/basic.vim' \
				--filepath="$HOME/.vimrc"
		fi
	}
	setup_util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_vim "$@"
fi
