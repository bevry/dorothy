#!/usr/bin/env bash

# https://github.com/chmln/sd
# sed/awk alternative

# https://github.com/chmln/sd/releases
# sd-v1.0.0-aarch64-apple-darwin.tar.gz
# sd-v1.0.0-aarch64-unknown-linux-musl.tar.gz
# sd-v1.0.0-arm-unknown-linux-gnueabihf.tar.gz
# sd-v1.0.0-armv7-unknown-linux-gnueabihf.tar.gz
# sd-v1.0.0-x86_64-apple-darwin.tar.gz
# sd-v1.0.0-x86_64-pc-windows-gnu.zip
# sd-v1.0.0-x86_64-pc-windows-msvc.zip
# sd-v1.0.0-x86_64-unknown-linux-gnu.tar.gz
# sd-v1.0.0-x86_64-unknown-linux-musl.tar.gz

# https://repology.org/project/sd-find-replace/versions

function setup_util_sd() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='sd'
		# no urpmi
		AUR='sd'
		BREW='sd'
		BSD='sd'
		CARGO='sd'
		EMERGE='sys-apps/sd'
		EOPKG='sd'
		NIX='sd'
		# RPM='sd' # repology is wrong, `sd` does not exist, there is no alternative
		SCOOP='sd'
		XBPS='sd'
		ZYPPER='sd'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='chmln/sd' glob='sd' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-apple-darwin.tar.gz' "$glob" || :
		else
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-armv7-unknown-linux-gnueabihf.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_sd "$@"
fi
