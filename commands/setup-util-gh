# https://github.com/cli/cli/releases/download/v2.42.0/gh_2.42.0_windows_386.msi
# https://github.com/cli/cli/releases/download/v2.42.0/gh_2.42.0_windows_386.zip
# https://github.com/cli/cli/releases/download/v2.42.0/gh_2.42.0_windows_amd64.msi
# https://github.com/cli/cli/releases/download/v2.42.0/gh_2.42.0_windows_amd64.zip
# https://github.com/cli/cli/releases/download/v2.42.0/gh_2.42.0_windows_arm64.zip

function setup_util_gh() (
	source "$DOROTHY/sources/util.bash"
	source "$(type -P setup-util)" # enable *_EVAL
	util_options=(
		--name='GitHub CLI'
		--cli=gh
		--configure-eval='__configure'
		APK_REPO='http://dl-cdn.alpinelinux.org/alpine/edge/community'
		APK='github-cli'
		APT_KEY='https://cli.github.com/packages/githubcli-archive-keyring.gpg'
		APT_REPO='deb [arch={ARCH} signed-by={KEY}] https://cli.github.com/packages stable main'
		APT='gh'
		AUR='github-cli'
		BREW='gh'
		DNF_REPO='https://cli.github.com/packages/rpm/gh-cli.repo'
		DNF='gh'
		ZYPPER_REPO='https://cli.github.com/packages/rpm/gh-cli.repo'
		ZYPPER='gh'
	)
	function __reconfigure {
		# check if we can auth
		if [[ $SETUP_UTIL__INSTALLED == 'yes' && $IS_STDIN_OPENED_ON_TERMINAL == 'yes' ]]; then
			# check if we aren't authed
			if ! gh auth status &>/dev/null; then
				# check if we want to auth
				if confirm --linger --negative --ppid=$$ -- 'Authenticate with the GitHub CLI?' 'You must authenticate to use the GitHub CLI. Authenticating also prevents Rate Limit errors.'; then
					gh auth login || : # we don't care if auth fails, as is irrelevant to installation
				fi
			fi
		fi
	}

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='cli/cli' glob='gh' arch
	arch="$(__get_arch)"
	if is-system --snap; then
		# gh via snap cannot access and authenticate without sudo, so ensure gh via snap is uninstalled
		setup-util --uninstall --dependency --cli=gh SNAP='gh'
	fi
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_macOS_arm64.zip' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_macOS_amd64.zip' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_arm64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_arm64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_armv6.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_armv6.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_armv6.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_amd64.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_amd64.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_amd64.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_linux_386.deb' || :
			__fetch_and_add_rpm_option_via_slug_suffix "$slug" '_linux_386.rpm' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_linux_386.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_gh "$@"
fi
