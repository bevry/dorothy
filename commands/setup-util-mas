#!/usr/bin/env bash

function setup_util_mas() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Mac App Store CLI'
		--cli='mas'
		--configure-eval='__configure'
		BREW='mas'
	)

	# checks
	if ! __is_macos; then
		__print_style --stderr --notice="[$0] is only intended to be run on macOS systems, skipping." || return $?
		return 0
	fi

	function __configure {
		if [[ $SETUP_UTIL__INSTALLED == 'yes' && $SETUP_UTIL__EXTRA == 'yes' ]]; then

			# =====================================
			# Configuration

			source "$DOROTHY/sources/config.sh"

			# setup.bash provides:
			local MAS_INSTALL=() # tuple array of id, label
			load_dorothy_config 'setup.bash'

			# =====================================
			# Action

			# action
			if [[ ${#MAS_INSTALL[@]} -ne 0 ]]; then
				# select packages
				local choices=()
				__split --target={choices} --no-zero-length --invoke -- \
					choose --multi \
					--question="Which Mac App Store apps would you like to install?" \
					--label -- "${MAS_INSTALL[@]}"
				setup-util --install="$option_install" --upgrade="$option_upgrade" --transpose=MAS -- "${choices[@]}"
			fi

			# upgrade
			if [[ $SETUP_UTIL__UPGRADE == 'yes' ]]; then
				# upgrade
				eval-helper --verbose --wrap -- \
					mas upgrade || :
			fi

			# configure
			if [[ $option_configure == 'yes' ]]; then
				# update MAS_INSTALL with all that are installed
				local id name
				while read -r id name; do
					if ! __has --source={MAS_INSTALL} -- "$id"; then
						MAS_INSTALL+=("$id" "$name")
					fi
				done <<<"$(mas list | cut -w -f1,2 | sort --ignore-case -k 2)"

				# save
				dorothy-config 'setup.bash' -- \
					--field='MAS_INSTALL' --columns=2 --array="$(__print_lines "${MAS_INSTALL[@]}" | sort --ignore-case -k 2)"
			fi
		fi
	}

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}" || return $?
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_mas "$@"
fi
