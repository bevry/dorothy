function setup_util_super_productivity (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Super Productivity'
		--app='Super Productivity' # .desktop, .appimage
	)

	# fetch and use configuration
	if __is_windows; then
		util_options+=(
			SCOOP_BUCKET='extras'
			SCOOP='super-productivity'
			WINGET='9nhfvg8361tw'
		)
	else
		util_options+=(
			AUR='superproductivity-bin'
			CASK='super-productivity'
			SNAP='superproductivity'
			FLATPAK='com.super_productivity.SuperProductivity'
		)

		# improve performance for detectable utilities when fetching asset configuration
		if setup-util check "${util_options[@]}" "${user_options[@]}"; then
			return 0
		fi

		# fetch and use configuration
		local slug='super-productivity/super-productivity' arch
		arch="$(__get_arch)"
		if __is_macos; then
			if [[ $arch == 'a64' ]]; then
				__fetch_and_add_download_option_via_slug_suffix "$slug" '-arm64.dmg' || :
			elif [[ $arch == 'x64' ]]; then
				__fetch_and_add_download_option_via_slug_suffix "$slug" '-x64.dmg' || :
			fi
		elif __is_linux; then
			if [[ $arch == 'a64' ]]; then
				__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-arm64.deb' || :
				__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-aarch64.rpm' || :
				__fetch_and_add_appimage_option_via_slug_suffix "$slug" '-linux-arm64.AppImage' || :
			elif [[ $arch == 'a32' ]]; then
				__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-armv7l.deb' || :
				__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-armv7l.rpm' || :
				__fetch_and_add_appimage_option_via_slug_suffix "$slug" '-linux-armv7l.AppImage' || :
			elif [[ $arch == 'x64' ]]; then
				__fetch_and_add_deb_option_via_slug_suffix "$slug" '-linux-amd64.deb' || :
				__fetch_and_add_rpm_option_via_slug_suffix "$slug" '-linux-x86_64.rpm' || :
				__fetch_and_add_appimage_option_via_slug_suffix "$slug" '-linux-x86_64.AppImage' || :
			fi
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_legsuper_productivity
fi
