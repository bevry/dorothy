#!/usr/bin/env bash

# https://zsh.sourceforge.io

# https://packages.debian.org/sid/amd64/zsh/filelist
# /bin/rzsh
# /bin/zsh
# /bin/zsh5

# https://github.com/ohmyzsh/ohmyzsh/wiki/Installing-ZSH

function setup_util_zsh() (
	source "$DOROTHY/sources/util.bash"
	source "$(type -P setup-util)" # enable *_EVAL
	util_options=(
		--name='zsh'
		--cli='zsh'
		--configure-eval='__configure'
		APK='zsh'
		APT='zsh'
		AUR='zsh'
		BREW='zsh'
		BSD='zsh'
		EMERGE='zsh'
		EOPKG='zsh'
		PORT='zsh'
		RPM='zsh'
		XBPS='zsh'
		ZYPPER='zsh'
	)
	function __after_eval {
		if [[ $SETUP_UTIL__INSTALLED == 'yes' ]]; then
			# https://zsh.sourceforge.io/Intro/intro_3.html
			# `.zshenv` needs to be in `$HOME` but all others inside `$ZDOTDIR`
			# `$ZDOTDIR` guaranteed by `setup-environment-commands`
			fs-mkdir -- "$ZDOTDIR" || return $? # required for opensuse
			fs-move -- "$ZDOTDIR/.zshenv" "$HOME/.zshenv" || return $?
			fs-move -- "$HOME/.zprofile" "$ZDOTDIR/.zprofile" || return $?
			fs-move -- "$HOME/.zshrc" "$ZDOTDIR/.zshrc" || return $?
			fs-move -- "$HOME/.zlogin" "$ZDOTDIR/.zlogin" || return $?
			fs-move -- "$HOME/.zlogout" "$ZDOTDIR/.zlogout" || return $?
			config-helper --file="$HOME/.zshenv" -- \
				--find='ZDOTDIR=.+' --replace="ZDOTDIR='$ZDOTDIR'" || return $?
		fi
	}
	setup_util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_zsh "$@"
fi
