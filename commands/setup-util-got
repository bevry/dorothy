#!/usr/bin/env bash

# https://github.com/melbahja/got

# https://github.com/melbahja/got/releases
# got_0.7.0_Darwin_amd64.tar.gz
# got_0.7.0_Darwin_arm64.tar.gz
# got_0.7.0_Freebsd_32bit.tar.gz
# got_0.7.0_Freebsd_amd64.tar.gz
# got_0.7.0_Freebsd_arm64.tar.gz
# got_0.7.0_Freebsd_armv6.tar.gz
# got_0.7.0_Linux_32bit.tar.gz
# got_0.7.0_Linux_amd64.tar.gz

# Unmaintained. Last release: 2022-08-01
# https://github.com/melbahja/got
# got [global options] command [command options] [arguments...]
# --dir directory, -d directory    Save downloaded file to a directory.
# --header value, -H value         Set these HTTP-Headers on the requests. The format has to be: -H "Key: Value"
# --output path, -o path           Download path, if dir passed, the path will be `dir + output`.

function setup_util_got() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli=got
		GO='github.com/melbahja/got' # /cmd/got
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='melbahja/got' glob='got' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_Darwin_arm64.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_Darwin_amd64.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_Linux_amd64.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '_Linux_32bit.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_got "$@"
fi
