#!/usr/bin/env bash

# https://github.com/mvdan/sh#shfmt

# DEBIAN/APT doesn't seem to exist
# No apt package "shfmt", but there is a snap with that name.

# https://github.com/mvdan/sh/releases
# shfmt_v3.7.0_darwin_amd64
# shfmt_v3.7.0_darwin_arm64
# shfmt_v3.7.0_linux_386
# shfmt_v3.7.0_linux_amd64
# shfmt_v3.7.0_linux_arm
# shfmt_v3.7.0_linux_arm64
# shfmt_v3.7.0_windows_386.exe
# shfmt_v3.7.0_windows_amd64.exe

function setup_util_shfmt() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='shfmt'
		APK='shfmt'
		AUR='shfmt'
		BREW='shfmt'
		BSD='shfmt'
		GO='mvdan.cc/sh/v3/cmd/shfmt'
		INSTALLER='https://webinstall.dev/shfmt'
		NIX='shfmt'
		PORT='shfmt'
		SCOOP='shfmt'
		SNAP='shfmt'
		XBPS='shfmt'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='mvdan/sh' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '_darwin_arm64' || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '_darwin_amd64' || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '_linux_arm64' || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '_linux_arm' || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '_linux_amd64' || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '_linux_386' || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_shfmt "$@"
fi
