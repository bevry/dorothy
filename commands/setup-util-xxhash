#!/usr/bin/env bash

# https://xxhash.com
# https://github.com/Cyan4973/xxHash
# https://github.com/Cyan4973/xxHash/releases/tag/v0.8.3

# https://repology.org/project/xxhash/versions

function setup_util_xxhash() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='xxhsum'
		# despite docs, no apk
		BREW='xxhash'
		APK='xxhash'
		AUR='xxhash'
		APT='xxhash'
		RPM='xxhash'
		VOID='xxHash'
		ZYPPER='xxhash'
		GENTOO='dev-libs/xxhash'
		NIX='xxHash'
	)
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_xxhash "$@"
fi
