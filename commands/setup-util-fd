#!/usr/bin/env bash

# https://github.com/sharkdp/fd
# find alternative

# https://github.com/sharkdp/fd/releases
# fd-musl_8.7.0_amd64.deb
# fd-musl_8.7.0_i686.deb
# fd-v8.7.0-aarch64-unknown-linux-gnu.tar.gz
# fd-v8.7.0-arm-unknown-linux-gnueabihf.tar.gz
# fd-v8.7.0-arm-unknown-linux-musleabihf.tar.gz
# fd-v8.7.0-i686-pc-windows-msvc.zip
# fd-v8.7.0-i686-unknown-linux-gnu.tar.gz
# fd-v8.7.0-i686-unknown-linux-musl.tar.gz
# fd-v8.7.0-x86_64-apple-darwin.tar.gz
# fd-v8.7.0-x86_64-pc-windows-gnu.zip
# fd-v8.7.0-x86_64-pc-windows-msvc.zip
# fd-v8.7.0-x86_64-unknown-linux-gnu.tar.gz
# fd-v8.7.0-x86_64-unknown-linux-musl.tar.gz
# fd_8.7.0_amd64.deb
# fd_8.7.0_arm64.deb
# fd_8.7.0_armhf.deb
# fd_8.7.0_i686.deb

# https://packages.debian.org/sid/amd64/fd-find/filelist
# /usr/bin/fdfind
# /usr/lib/cargo/bin/fd

function setup_util_fd() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='fd'
		APT='fd-find'
		AUR='fd'
		BREW='fd'
		BSD='fd-find'
		CARGO='fd-find'
		EMERGE='fd'
		NIX='fd'
		NODE='fd-find'
		PORT='fd'
		RPM='fd-find'
		SCOOP='fd'
		XBPS='fd'
		ZYPPER='fd'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='sharkdp/fd' glob='*/fd' arch
	arch="$(__get_arch)"
	if __is_macos; then
		__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' "$glob" || :
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_arm64.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-unknown-linux-gnu.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_armhf.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-arm-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_amd64.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_i686.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-i686-unknown-linux-musl.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_fd "$@"
fi
