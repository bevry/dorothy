#!/usr/bin/env bash

# https://prettier.io/docs/en/install.html

function setup_util_prettier() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Prettier'
		--cli='prettier'
		NODE='prettier'
	)
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_prettier "$@"
fi
