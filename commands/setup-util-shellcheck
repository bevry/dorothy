#!/usr/bin/env bash
# trunk-ignore-all(shellcheck/SC1073)
# trunk-ignore-all(shellcheck/SC1072)

# https://github.com/koalaman/shellcheck#installing

# https://github.com/koalaman/shellcheck/releases
# shellcheck-v0.9.0.darwin.x86_64.tar.xz
# shellcheck-v0.9.0.linux.aarch64.tar.xz
# shellcheck-v0.9.0.linux.armv6hf.tar.xz
# shellcheck-v0.9.0.linux.x86_64.tar.xz
# shellcheck-v0.9.0.zip

# https://packages.debian.org/sid/amd64/shellcheck/filelist
# /usr/bin/shellcheck

function setup_util_shellcheck() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='shellcheck'
		# prefer apt last, as it installs an outdated version
		--source='... apt'
		# no apk
		APT='shellcheck'
		AUR='shellcheck'
		BREW='shellcheck'
		BSD='shellcheck'
		CABAL='ShellCheck'
		CONDA_CHANNEL='conda-forge'
		CONDA='shellcheck'
		EMERGE='shellcheck'
		EOPKG='shellcheck'
		NIX='nixpkgs.shellcheck'
		PORT='shellcheck'
		RPM='ShellCheck'
		SCOOP='shellcheck'
		SNAP_CHANNEL='edge'
		SNAP='shellcheck'
		ZYPPER='ShellCheck'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='koalaman/shellcheck' glob='*/shellcheck' arch
	if __is_macos; then
		__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.darwin.x86_64.tar.xz' "$glob" || :
	else
		arch="$(__get_arch)"
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.linux.aarch64.tar.xz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.linux.armv6hf.tar.xz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '.linux.x86_64.tar.xz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_shellcheck "$@"
fi
