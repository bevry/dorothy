#!/usr/bin/env bash

# https://docs.asciinema.org/getting-started/
# https://github.com/asciinema/asciinema/releases

# asciinema-aarch64-apple-darwin
# asciinema-aarch64-unknown-linux-gnu
# asciinema-x86_64-apple-darwin
# asciinema-x86_64-unknown-linux-gnu
# asciinema-x86_64-unknown-linux-musl

function setup_util_asciinema() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='asciinema'
		APT='asciinema'
		AUR='asciinema'
		BREW='asciinema'
		CARGO='asciinema'
		EOPKG='asciinema'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='asciinema/asciinema' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" 'aarch64-apple-darwin' || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" 'x86_64-apple-darwin' || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" 'aarch64-unknown-linux-gnu' || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" 'x86_64-unknown-linux-musl' || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_asciinema "$@"
fi
