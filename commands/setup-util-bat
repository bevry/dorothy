#!/usr/bin/env bash

# https://github.com/sharkdp/bat
# cat alternative

# https://github.com/sharkdp/bat/releases
# bat-musl_0.26.0_arm64.deb <-- musl only as prefix, not suffix
# bat-musl_0.26.0_musl-linux-amd64.deb <-- musl as prefix and suffix
# bat-musl_0.26.0_musl-linux-i686.deb <-- musl as prefix and suffix
# bat-v0.26.0-aarch64-apple-darwin.tar.gz
# bat-v0.26.0-aarch64-pc-windows-msvc.zip
# bat-v0.26.0-aarch64-unknown-linux-gnu.tar.gz
# bat-v0.26.0-aarch64-unknown-linux-musl.tar.gz
# bat-v0.26.0-arm-unknown-linux-gnueabihf.tar.gz
# bat-v0.26.0-arm-unknown-linux-musleabihf.tar.gz
# bat-v0.26.0-i686-pc-windows-msvc.zip
# bat-v0.26.0-i686-unknown-linux-gnu.tar.gz
# bat-v0.26.0-i686-unknown-linux-musl.tar.gz
# bat-v0.26.0-x86_64-apple-darwin.tar.gz
# bat-v0.26.0-x86_64-pc-windows-msvc.zip
# bat-v0.26.0-x86_64-unknown-linux-gnu.tar.gz
# bat-v0.26.0-x86_64-unknown-linux-musl.tar.gz
# bat_0.26.0_amd64.deb
# bat_0.26.0_arm64.deb
# bat_0.26.0_armhf.deb
# bat_0.26.0_i686.deb
# bat_0.26.0_musl-linux-armhf.deb <-- musl only as suffix

# https://repology.org/project/bat-cat/versions

function setup_util_bat() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='bat'
		# despite docs, no apk
		# aur is outdated, installs 0.24 <https://github.com/bevry/dorothy/actions/runs/19231237567/job/54970077887#step:4:26505> (which breaks `echo-file` tests) instead of 0.26
		APT='rust-bat'
		BREW='bat'
		BSD='sysutils/bat'
		CARGO='bat'
		EMERGE='sys-apps/bat'
		EOPKG='bat'
		NIX='bat'
		PORT='bat'
		RPM='bat' # repology is wrong, `rust-bat` is 404, correct is `bat.x86_64`
		SCOOP='bat'
		URPMI='bat'
		XBPS='bat'
		# ZYPPER='bat' # SUSE <-- outdated on leap, so install manually: https://github.com/bevry/dorothy/actions/runs/18323839922/job/52183264104#step:4:32671
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='sharkdp/bat' glob='*/bat' arch
	arch="$(__get_arch)"
	if __is_macos; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-apple-darwin.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-apple-darwin.tar.gz' "$glob" || :
		fi
	elif __is_linux; then
		if [[ $arch == 'a64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_arm64.deb' || : # there is a musl build, however it is prefix and not suffix
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-aarch64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_musl-linux-armhf.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-arm-unknown-linux-musleabihf.tar.gz' "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_musl-linux-amd64.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-x86_64-unknown-linux-musl.tar.gz' "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__fetch_and_add_deb_option_via_slug_suffix "$slug" '_musl-linux-i686.deb' || :
			__fetch_and_add_download_option_via_slug_suffix_glob "$slug" '-i686-unknown-linux-musl.tar.gz' "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_bat "$@"
fi
