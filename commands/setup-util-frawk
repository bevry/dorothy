#!/usr/bin/env bash

# https://github.com/ezrosent/frawk
# awk alternative

# https://github.com/ezrosent/frawk/releases
# no assets

function setup_util_frawk() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--cli='frawk'
		CARGO='frawk'
	)
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_frawk "$@"
fi
