#!/usr/bin/env bash

# https://github.com/BLAKE3-team/BLAKE3/releases/tag/1.8.2
# b3sum_linux_x64_bin
# b3sum_macos_x64_bin
# b3sum_windows_x64_bin.exe

# https://github.com/rhash/RHash <-- only available via brew, brew version lags behind, only 1.4.6 and above supports blake3, but brew is 1.4.5

# https://repology.org/project/b3sum/versions

function setup_util_b3sum() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		# despite docs, no apk
		--cli='b3sum'
		BREW='b3sum' # blake3 is the c implementation
		CARGO='b3sum'
		APK='b3sum'
		AUR='b3sum'
		RPM='b3sum'
		ZYPPER='b3sum'
		SCOOP='b3sum'
		VOID='b3sum'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local slug='BLAKE3-team/BLAKE3' arch
	arch="$(__get_arch)"
	if __is_macos; then
		__fetch_and_add_download_option_via_slug_suffix "$slug" '_macos_x64_bin' || :
	elif __is_linux; then
		if [[ $arch == 'x64' ]]; then
			__fetch_and_add_download_option_via_slug_suffix "$slug" '_linux_x64_bin' || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_b3sum "$@"
fi
