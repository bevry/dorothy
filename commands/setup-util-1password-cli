#!/usr/bin/env bash

# https://app-updates.agilebits.com/product_history/CLI
# https://app-updates.agilebits.com/product_history/CLI2

function setup_util_1password_cli() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='1Password CLI'
		--cli=op
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${user_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	local glob='op' arch platform version
	arch="$(__get_arch)"
	platform="$(uname -s)"
	version="v$(fetch 'https://app-updates.agilebits.com/product_history/CLI2' | echo-regexp -o --regexp='https://cache.agilebits.com/dist/1P/op2/pkg/v([^/-]+)/' --replace='$1')" # fetch latest cli version
	if [[ $platform == 'Darwin' ]]; then
		__add_option INSTALLER="https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_apple_universal_$version.pkg" INSTALLER_OPEN='yes' || :
		# uninstall cask version as it lags behind
		setup-util dependency uninstall --optional --name='1Password CLI' CASK='1password-cli'
	elif [[ $platform == 'Linux' ]]; then
		if [[ $arch == 'a64' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_linux_arm64_$version.zip" "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_linux_arm_$version.zip" "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_linux_amd64_$version.zip" "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_linux_386_$version.zip" "$glob" || :
		fi
	elif [[ $platform == 'FreeBSD' ]]; then
		if [[ $arch == 'a64' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_freebsd_arm64_$version.zip" "$glob" || :
		elif [[ $arch == 'a32' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_freebsd_arm_$version.zip" "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_freebsd_amd64_$version.zip" "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_freebsd_386_$version.zip" "$glob" || :
		fi
	elif [[ $platform == 'OpenBSD' ]]; then
		if [[ $arch == 'a64' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_openbsd_arm64_$version.zip" "$glob" || :
		elif [[ $arch == 'x64' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_openbsd_amd64_$version.zip" "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_openbsd_386_$version.zip" "$glob" || :
		fi
	elif [[ $platform == 'Windows' ]]; then
		if [[ $arch == 'x64' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_windows_amd64_$version.zip" "$glob" || :
		elif [[ $arch == 'x32' ]]; then
			__add_download_option_via_url_glob "https://cache.agilebits.com/dist/1P/op2/pkg/$version/op_windows_386_$version.zip" "$glob" || :
		fi
	fi

	# setup
	setup-util "${util_options[@]}" "${user_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_1password_cli "$@"
fi
