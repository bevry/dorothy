#!/usr/bin/env bash

# https://repology.org/project/hyper-terminal/versions
# https://hyper.is/#installation

function setup_util_hyper() (
	source "$DOROTHY/sources/util.bash"
	util_options=(
		--name='Hyper'
		--app='Hyper'
		--cli=hyper
	)

	# fetch and use configuration
	if __is_windows; then
		util_options+=(
			WINGET='Hyper'
			# no scoop
		)
	else
		util_options+=(
			AUR='hyper'
			CASK='hyper'
			NIX='hyper'
		)

		# improve performance for detectable utilities when fetching asset configuration
		if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
			return 0
		fi

		# fetch and use configuration
		local arch
		arch="$(__get_arch)"
		if __is_macos; then
			if [[ $arch == 'a64' ]]; then
				__fetch_and_add_dmg_option_via_url_glob_filename 'https://releases.hyper.is/download/mac' '*/Hyper.app' 'Hyper.app'
			elif [[ $arch == 'x64' ]]; then
				__fetch_and_add_dmg_option_via_url_glob_filename 'https://releases.hyper.is/download/mac_arm64' '*/Hyper.app' 'Hyper.app'
			fi
		elif __is_linux; then
			if [[ $arch == 'a64' ]]; then
				__add_deb_option_via_url 'https://releases.hyper.is/download/deb_arm64'
				__add_rpm_option_via_url 'https://releases.hyper.is/download/rpm_arm64'
				__add_appimage_option_via_url 'https://releases.hyper.is/download/AppImage_arm64'
			elif [[ $arch == 'x64' ]]; then
				__add_deb_option_via_url 'https://releases.hyper.is/download/deb'
				__add_rpm_option_via_url 'https://releases.hyper.is/download/rpm'
				__add_appimage_option_via_url 'https://releases.hyper.is/download/AppImage'
			fi
		fi
	fi
	setup-util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_hyper "$@"
fi
