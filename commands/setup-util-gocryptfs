#!/usr/bin/env bash

# https://github.com/rfjakob/gocryptfs

# https://github.com/rfjakob/gocryptfs/releases
# gocryptfs_v2.4.0_linux-static_amd64.tar.gz
# gocryptfs_v2.4.0_linux-static_amd64.tar.gz.asc
# gocryptfs_v2.4.0_src-deps.tar.gz
# gocryptfs_v2.4.0_src-deps.tar.gz.asc
# gocryptfs_v2.4.0_src.tar.gz
# gocryptfs_v2.4.0_src.tar.gz.asc

function setup_util_gocryptfs() (
	source "$DOROTHY/sources/bash.bash"
	source "$(type -P setup-util)" # enable *_EVAL
	util_options=(
		--cli='gocryptfs'
		--no-xdg # make it global, as must be available to alternative users, just chowning in the group still does not make it available to the group if it is in xdg
		GO='github.com/rfjakob/gocryptfs'
	)

	# improve performance for detectable utilities when fetching asset configuration
	if setup-util check "${util_options[@]}" "${setup_options[@]}"; then
		return 0
	fi

	# fetch and use configuration
	function __install {
		# dependencies
		setup-util-go --dependency || return $?
		setup-util-fuse --optional --quiet || return $?
		source "$DOROTHY/sources/environment.sh" || return $?

		# build
		# trunk-ignore(shellcheck/SC2211)
		./*/build.bash || return $?
	}
	function __add_download_option {
		local suffix="$1" url
		url="$(__get_github_asset_url_via_slug_suffix 'rfjakob/gocryptfs' "$suffix")" || return $?
		util_options+=(
			DOWNLOAD="$url"
			DOWNLOAD_ARCHIVE_EXTRACT='yes'
			DOWNLOAD_BUILD_INSTALL_EVAL='__install'
			DOWNLOAD_BUILD_GLOB='*/gocryptfs'
		)
	}
	__add_download_option '_src-deps.tar.gz' || :

	# setup
	setup_util "${util_options[@]}" "${setup_options[@]}"
)

# fire if invoked standalone
if [[ $0 == "${BASH_SOURCE[0]}" ]]; then
	setup_util_gocryptfs "$@"
fi
